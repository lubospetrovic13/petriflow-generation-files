<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>bug_tracker</id>
  <version>1.0.0</version>
  <initials>BUG</initials>
  <title>Bug Tracker</title>
  <icon>bug_report</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <caseEvents>
    <event type="create">
      <id>on_create</id>
      <actions phase="post">
        <action id="1">
<![CDATA[
            status: f.status;
            change status value { "Awaiting Triage" }
            ]]>
        </action>
      </actions>
    </event>
  </caseEvents>
  <role>
    <id>reporter</id>
    <title>Reporter</title>
  </role>
  <role>
    <id>triage</id>
    <title>Triage</title>
  </role>
  <role>
    <id>developer</id>
    <title>Developer</title>
  </role>
  <role>
    <id>qa</id>
    <title>QA Engineer</title>
  </role>
  <!-- ═══════════════════════════ DATA FIELDS ═══════════════════════════ -->
  <!-- Bug report fields -->
  <data type="text">
    <id>bug_title</id>
    <title>Bug Title</title>
    <desc>Short descriptive title of the bug</desc>
  </data>
  <data type="text">
    <id>description</id>
    <title>Description</title>
    <desc>Detailed description of the problem</desc>
  </data>
  <data type="text">
    <id>steps_to_reproduce</id>
    <title>Steps to Reproduce</title>
    <desc>Step-by-step instructions to reproduce the bug</desc>
  </data>
  <data type="enumeration_map">
    <id>severity</id>
    <title>Severity</title>
    <options>
      <option key="critical">Critical</option>
      <option key="high">High</option>
      <option key="medium">Medium</option>
      <option key="low">Low</option>
    </options>
  </data>
  <data type="text">
    <id>affected_component</id>
    <title>Affected Component</title>
    <desc>Which part of the system is affected</desc>
  </data>
  <data type="file">
    <id>screenshot</id>
    <title>Screenshot (optional)</title>
  </data>
  <data type="text">
    <id>reporter_email</id>
    <title>Reporter Email</title>
  </data>
  <!-- Triage fields -->
  <data type="enumeration_map">
    <id>internal_priority</id>
    <title>Internal Priority</title>
    <options>
      <option key="p1">P1 - Urgent</option>
      <option key="p2">P2 - High</option>
      <option key="p3">P3 - Normal</option>
      <option key="p4">P4 - Low</option>
    </options>
  </data>
  <data type="text">
    <id>triage_notes</id>
    <title>Triage Notes</title>
  </data>
  <data type="user">
    <id>assigned_developer</id>
    <title>Assigned Developer</title>
  </data>
  <!-- Developer fields -->
  <data type="text">
    <id>fix_description</id>
    <title>Description of Changes</title>
    <desc>Describe what was changed to fix the bug</desc>
  </data>
  <!-- QA fields -->
  <data type="enumeration_map">
    <id>qa_decision</id>
    <title>QA Decision</title>
    <options>
      <option key="pass">Pass — Fix Verified</option>
      <option key="fail">Fail — Rework Required</option>
    </options>
  </data>
  <data type="text">
    <id>qa_feedback</id>
    <title>Rejection Feedback</title>
    <desc>Required when rejecting the fix</desc>
  </data>
  <!-- Routing flags -->
  <data type="number">
    <id>go_resolved</id>
    <title>Go Resolved</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_rework</id>
    <title>Go Rework</title>
    <init>0</init>
  </data>
  <!-- Status and resolution summary -->
  <data type="text">
    <id>status</id>
    <title>Current Status</title>
  </data>
  <data type="text">
    <id>resolution_summary</id>
    <title>Resolution Summary</title>
    <desc>Summary of what was fixed — populated on resolution</desc>
  </data>
  <data type="text">
    <id>rework_count_display</id>
    <title>Rework Cycles</title>
  </data>
  <data type="number">
    <id>rework_count</id>
    <title>Rework Count Internal</title>
    <init>0</init>
  </data>
  <!-- ═══════════════════════════ TRANSITIONS ═══════════════════════════ -->
  <!-- T1: Submit Bug Report -->
  <transition>
    <id>submit_bug</id>
    <x>208</x>
    <y>208</y>
    <label>Submit Bug Report</label>
    <icon>bug_report</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>reporter</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_submit</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Bug Report</title>
      <dataRef>
        <id>bug_title</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>steps_to_reproduce</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>severity</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>affected_component</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>3</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>screenshot</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>reporter_email</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>5</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>submit_finish</id>
      <actions phase="pre">
        <action id="2">
<![CDATA[
            status: f.status;
            change status value { "Awaiting Triage" }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- T2: Triage -->
  <transition>
    <id>triage_review</id>
    <x>400</x>
    <y>208</y>
    <label>Triage Review</label>
    <icon>manage_search</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>triage</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_triage</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Triage</title>
      <dataRef>
        <id>bug_title</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>steps_to_reproduce</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>severity</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>affected_component</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>3</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>screenshot</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>internal_priority</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>5</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>assigned_developer</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>5</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>triage_notes</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>6</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>triage_finish</id>
      <actions phase="pre">
        <action id="3">
<![CDATA[
            status: f.status;
            change status value { "In Development" }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- T3: Developer Fix -->
  <transition>
    <id>dev_fix</id>
    <x>592</x>
    <y>208</y>
    <label>Develop Fix</label>
    <icon>code</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>developer</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_dev</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Fix Development</title>
      <dataRef>
        <id>bug_title</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>steps_to_reproduce</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>severity</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>internal_priority</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>3</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>triage_notes</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>qa_feedback</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>5</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>fix_description</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>6</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>dev_finish</id>
      <actions phase="pre">
        <action id="4">
<![CDATA[
            status: f.status;
            change status value { "Awaiting QA Verification" }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- T4: QA Verify -->
  <transition>
    <id>qa_verify</id>
    <x>784</x>
    <y>208</y>
    <label>QA Verification</label>
    <icon>verified</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>qa</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_qa</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>QA Verification</title>
      <dataRef>
        <id>bug_title</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>steps_to_reproduce</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>fix_description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>qa_decision</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <event type="set">
          <id>qa_decision_set</id>
          <actions phase="post">
            <action id="5">
<![CDATA[
                t_qa: t.qa_verify, qa_decision: f.qa_decision, qa_feedback: f.qa_feedback;
                if (qa_decision.value == "fail") {
                make qa_feedback, editable  on t_qa when { true }
                make qa_feedback, required  on t_qa when { true }
                } else {
                make qa_feedback, hidden    on t_qa when { true }
                make qa_feedback, optional  on t_qa when { true }
                }
                ]]>
            </action>
          </actions>
        </event>
      </dataRef>
      <dataRef>
        <id>qa_feedback</id>
        <logic>
          <behavior>hidden</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>5</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>qa_finish</id>
      <actions phase="pre">
        <action id="6">
<![CDATA[
            go_resolved: f.go_resolved, go_rework: f.go_rework,
            qa_decision: f.qa_decision, status: f.status,
            rework_count: f.rework_count, rework_count_display: f.rework_count_display,
            fix_description: f.fix_description, resolution_summary: f.resolution_summary;
            if (qa_decision.value == "pass") {
            change go_resolved value { 1 }
            change go_rework   value { 0 }
            change status      value { "Resolved" }
            change resolution_summary value { fix_description.value }
            } else {
            change go_resolved value { 0 }
            change go_rework   value { 1 }
            def current = (rework_count.value as Integer) ?: 0
            change rework_count         value { (current + 1) as Double }
            change rework_count_display value { "Rework cycle ${current + 1}" }
            change status               value { "Rework Required" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="7">
<![CDATA[
            qa_decision: f.qa_decision, reporter_email: f.reporter_email,
            bug_title: f.bug_title, resolution_summary: f.resolution_summary;
            if (qa_decision.value == "pass") {
            sendEmail(
            [reporter_email.value],
            "Your bug report has been resolved: ${bug_title.value}",
            "Good news! The bug you reported has been verified and resolved.\n\nResolution summary:\n${resolution_summary.value}\n\nThank you for your report."
            )
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- T5: Detail View (persistent, reporter) -->
  <transition>
    <id>detail_view</id>
    <x>400</x>
    <y>16</y>
    <label>My Bug Status</label>
    <icon>info</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>2</priority>
    <roleRef>
      <id>reporter</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_detail</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Bug Report Status</title>
      <dataRef>
        <id>bug_title</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>severity</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>internal_priority</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
