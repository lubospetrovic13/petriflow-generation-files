  <!-- T5: Route after both reviews -->
  <transition>
    <id>route_after_reviews</id>
    <x>976</x>
    <y>208</y>
    <label>Route After Reviews</label>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <trigger type="auto"/>
    <event type="finish">
      <id>route_finish</id>
      <actions phase="pre">
        <action id="5">
<![CDATA[
            legal_decision: f.legal_decision, finance_decision: f.finance_decision,
            go_manager: f.go_manager, go_revise: f.go_revise, status: f.status,
            legal_comment: f.legal_comment, finance_comment: f.finance_comment;
            def lApprove = (legal_decision.value == "approve")
            def fApprove = (finance_decision.value == "approve")
            if (lApprove && fApprove) {
            change go_manager value { 1 }
            change go_revise value { 0 }
            change status value { "Pending Manager Approval" }
            } else {
            change go_manager value { 0 }
            change go_revise value { 1 }
            change status value { "Rejected — Revision Required" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="6">
<![CDATA[
            legal_decision: f.legal_decision, finance_decision: f.finance_decision,
            submitter_email: f.submitter_email, legal_comment: f.legal_comment,
            finance_comment: f.finance_comment, go_revise: f.go_revise;
            if ((go_revise.value as Integer) == 1) {
            def reasons = []
            if (legal_decision.value == "reject") reasons << "Legal: ${legal_comment.value}"
            if (finance_decision.value == "reject") reasons << "Finance: ${finance_comment.value}"
            sendEmail(
            [submitter_email.value],
            "Purchase Order Revision Required",
            "Your purchase order requires revision.\n\nRejection reasons:\n" + reasons.join("\n\n") +
            "\n\nPlease log in to revise and resubmit your request."
            )
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
