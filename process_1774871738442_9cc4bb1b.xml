  <data type="number">
    <id>go_split</id>
    <title>Go Split</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>legal_approve</id>
    <title>Legal Approve</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>legal_reject</id>
    <title>Legal Reject</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>finance_approve</id>
