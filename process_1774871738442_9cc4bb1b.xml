    <init>0</init>
  </data>
  <data type="number">
    <id>go_revise</id>
    <title>Go Revise</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_issue</id>
    <title>Go Issue</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_final_reject</id>
    <title>Go Final Reject</title>
