<![CDATA[
            legal_approve: f.legal_approve, legal_reject: f.legal_reject, legal_decision: f.legal_decision;
            if (legal_decision.value == "approve") {
            change legal_approve value { 1 }
            change legal_reject value { 0 }
            } else {
