<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>public_request_process</id>
  <version>1.0.0</version>
  <initials>PRP</initials>
  <title>Public Request and Communication</title>
  <icon>public</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>true</anonymousRole>
  <transitionRole>false</transitionRole>
  <role>
    <id>registration</id>
    <title>Registration Desk</title>
  </role>
  <role>
    <id>legal</id>
    <title>Legal Department</title>
  </role>
  <role>
    <id>pr</id>
    <title>PR Department</title>
  </role>
  <data type="text">
    <id>first_name</id>
    <title>First Name</title>
  </data>
  <data type="text">
    <id>last_name</id>
    <title>Last Name</title>
  </data>
  <data type="text">
    <id>email</id>
    <title>Email</title>
  </data>
  <data type="text">
    <id>phone</id>
    <title>Phone Number</title>
  </data>
  <data type="text">
    <id>description</id>
    <title>Request Description</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="file">
    <id>attachment</id>
    <title>Attachment</title>
  </data>
  <data type="enumeration_map">
    <id>route_selection</id>
    <title>Route To</title>
    <options>
      <option key="legal">Legal Department</option>
      <option key="pr">PR Department (Direct)</option>
    </options>
  </data>
  <data type="text">
    <id>legal_statement</id>
    <title>Formal Legal Statement</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="text">
    <id>pr_answer</id>
    <title>Final Answer to Submitter</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="text">
    <id>status</id>
    <title>Current Status</title>
    <init>Submitted</init>
  </data>
  <data type="number">
    <id>to_legal</id>
    <title>To Legal</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>to_pr</id>
    <title>To PR</title>
    <init>0</init>
  </data>
  <transition>
    <id>submit_request</id>
    <x>112</x>
    <y>208</y>
    <label>Submit Request</label>
    <icon>send</icon>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>anonymous</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_submit</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Request Form</title>
      <dataRef>
        <id>first_name</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>last_name</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>email</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>phone</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>submit_finish</id>
      <actions phase="pre">
        <action id="1">status: f.status;
                    change status value { "Pending Triage" }</action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>triage</id>
    <x>496</x>
    <y>208</y>
    <label>Triage Request</label>
    <icon>rule</icon>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>registration</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_triage</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Review and Route</title>
      <dataRef>
        <id>first_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>last_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>route_selection</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>triage_finish</id>
      <actions phase="pre">
        <action id="2">sel: f.route_selection, to_l: f.to_legal, to_p: f.to_pr, status: f.status;
                    if (sel.value == "legal") {
                        change to_l value { 1 }; change to_p value { 0 };
                        change status value { "Under Legal Review" }
                    } else {
                        change to_l value { 0 }; change to_p value { 1 };
                        change status value { "Under PR Review" }
                    }</action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>legal_review</id>
    <x>688</x>
    <y>112</y>
    <label>Legal Statement</label>
    <icon>gavel</icon>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>legal</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_legal</id>
      <cols>1</cols>
      <layout>grid</layout>
      <title>Legal Review</title>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>legal_finish</id>
      <actions phase="pre">
        <action id="3">status: f.status;
                    change status value { "Under PR Review" }</action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>pr_final</id>
    <x>880</x>
    <y>208</y>
    <label>PR Answer</label>
    <icon>chat</icon>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>pr</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_pr</id>
      <cols>1</cols>
      <layout>grid</layout>
      <title>Final Response</title>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>pr_answer</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>pr_finish</id>
      <actions phase="pre">
        <action id="4">status: f.status;
                    change status value { "Completed" }</action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>view_status</id>
    <x>496</x>
    <y>16</y>
    <label>Track My Request</label>
    <icon>visibility</icon>
    <priority>2</priority>
    <roleRef>
      <id>anonymous</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_status</id>
      <cols>1</cols>
      <layout>grid</layout>
      <title>Request Status</title>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>pr_answer</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <place>
    <id>p_start</id>
    <x>16</x>
    <y>208</y>
    <label>Start</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_triage</id>
    <x>304</x>
    <y>208</y>
    <label>Pending Triage</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_legal</id>
    <x>688</x>
    <y>208</y>
    <label>Legal Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_pr</id>
    <x>880</x>
    <y>112</y>
    <label>PR Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_status_active</id>
    <x>304</x>
    <y>16</y>
    <label>Status Active</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_end</id>
    <x>1072</x>
    <y>208</y>
    <label>Finished</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <arc>
    <id>a1</id>
    <type>regular</type>
    <sourceId>p_start</sourceId>
    <destinationId>submit_request</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2</id>
    <type>regular</type>
    <sourceId>submit_request</sourceId>
    <destinationId>p_triage</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3</id>
    <type>regular</type>
    <sourceId>submit_request</sourceId>
    <destinationId>p_status_active</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a4</id>
    <type>read</type>
    <sourceId>p_status_active</sourceId>
    <destinationId>view_status</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a5</id>
    <type>regular</type>
    <sourceId>p_triage</sourceId>
    <destinationId>triage</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a6</id>
    <type>regular</type>
    <sourceId>triage</sourceId>
    <destinationId>p_legal</destinationId>
    <multiplicity>0</multiplicity>
    <reference>to_legal</reference>
  </arc>
  <arc>
    <id>a7</id>
    <type>regular</type>
    <sourceId>triage</sourceId>
    <destinationId>p_pr</destinationId>
    <multiplicity>0</multiplicity>
    <reference>to_pr</reference>
  </arc>
  <arc>
    <id>a8</id>
    <type>regular</type>
    <sourceId>p_legal</sourceId>
    <destinationId>legal_review</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a9</id>
    <type>regular</type>
    <sourceId>legal_review</sourceId>
    <destinationId>p_pr</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a10</id>
    <type>regular</type>
    <sourceId>p_pr</sourceId>
    <destinationId>pr_final</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a11</id>
    <type>regular</type>
    <sourceId>pr_final</sourceId>
    <destinationId>p_end</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
</document>