  <!-- HR approve/reject variable arcs -->
  <arc>
    <id>a6a</id>
    <type>regular</type>
    <sourceId>hr_review</sourceId>
    <destinationId>p_final</destinationId>
    <multiplicity>0</multiplicity>
    <reference>go_hr_approve</reference>
  </arc>
  <arc>
    <id>a6b</id>
    <type>regular</type>
    <sourceId>hr_review</sourceId>
    <destinationId>start</destinationId>
    <multiplicity>0</multiplicity>
    <reference>go_hr_reject</reference>
  </arc>
