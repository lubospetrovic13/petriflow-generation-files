<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>hr_leave_request</id>
  <version>1.0.0</version>
  <initials>HRL</initials>
  <title>HR Leave Request Workflow</title>
  <icon>event</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <caseEvents>
    <event type="create">
      <id>on_create</id>
      <actions phase="post">
        <action id="1">
<![CDATA[
            async.run { assignTask("submit_request"); finishTask("submit_request") }
            ]]>
        </action>
      </actions>
    </event>
  </caseEvents>
  <role>
    <id>employee</id>
    <title>Employee</title>
  </role>
  <role>
    <id>manager</id>
    <title>Manager</title>
  </role>
  <role>
    <id>hr</id>
    <title>HR Officer</title>
  </role>
  <role>
    <id>system</id>
    <title>System</title>
  </role>
  <data type="enumeration_map">
    <id>leave_type</id>
    <title>Leave Type</title>
    <options>
      <option key="annual">Annual Leave</option>
      <option key="sick">Sick Leave</option>
      <option key="personal">Personal Leave</option>
    </options>
  </data>
  <data type="date">
    <id>start_date</id>
    <title>Start Date</title>
  </data>
  <data type="date">
    <id>end_date</id>
    <title>End Date</title>
  </data>
  <data type="text">
    <id>reason</id>
    <title>Reason</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="file">
    <id>attachment</id>
    <title>Attachment</title>
    <component>
      <name>preview</name>
    </component>
  </data>
  <data type="text">
    <id>manager_comment</id>
    <title>Manager Comment</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="text">
    <id>hr_comment</id>
    <title>HR Comment</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="enumeration_map">
    <id>status</id>
    <title>Status</title>
    <options>
      <option key="draft">Draft</option>
      <option key="manager_review">Manager Review</option>
      <option key="manager_rejected">Manager Rejected</option>
      <option key="hr_review">HR Review</option>
      <option key="hr_rejected">HR Rejected</option>
      <option key="approved">Approved</option>
    </options>
    <init>draft</init>
  </data>
  <data type="text">
    <id>employee_email</id>
    <title>Employee Email</title>
  </data>
  <data type="number">
    <id>go_manager_approve</id>
    <title>Go Manager Approve</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_manager_reject</id>
    <title>Go Manager Reject</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_hr_approve</id>
    <title>Go HR Approve</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_hr_reject</id>
    <title>Go HR Reject</title>
    <init>0</init>
  </data>
  <data type="taskRef">
    <id>status_view</id>
    <title>Status View</title>
    <init>status_task</init>
  </data>
  <transition>
    <id>submit_request</id>
    <x>112</x>
    <y>208</y>
    <label>Submit Leave Request</label>
    <icon>send</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>employee</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>submit_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Leave Request</title>
      <dataRef>
        <id>leave_type</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>start_date</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>end_date</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>reason</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="assign">
      <id>submit_assign</id>
      <actions phase="pre">
        <action id="2">
<![CDATA[
            employee_email: f.employee_email;
            change employee_email value { userService.loggedOrSystem.email }
            ]]>
        </action>
      </actions>
    </event>
    <event type="finish">
      <id>submit_finish</id>
      <actions phase="pre">
        <action id="3">
<![CDATA[
            go_manager_approve: f.go_manager_approve, go_manager_reject: f.go_manager_reject, status: f.status;
            change go_manager_approve value { 1 }; change go_manager_reject value { 0 };
            change status value { "manager_review" }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="4">
<![CDATA[
            async.run { assignTask("manager_review"); finishTask("manager_review") }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>manager_review</id>
    <x>304</x>
    <y>208</y>
    <label>Manager Review</label>
    <icon>assignment_ind</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>manager</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>manager_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Manager Decision</title>
      <dataRef>
        <id>manager_comment</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>leave_type</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>start_date</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>end_date</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>2</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>reason</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>manager_finish</id>
      <actions phase="pre">
        <action id="5">
<![CDATA[
            go_manager_approve: f.go_manager_approve, go_manager_reject: f.go_manager_reject, status: f.status;
            // Approve or reject based on manager's decision (approve if comment starts with "APPROVE", else reject)
            def comment = (f.manager_comment.value ?: "").trim().toLowerCase()
            if (comment.startsWith("approve")) {
            change go_manager_approve value { 1 }; change go_manager_reject value { 0 };
            change status value { "hr_review" }
            } else {
            change go_manager_approve value { 0 }; change go_manager_reject value { 1 };
            change status value { "manager_rejected" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="6">
<![CDATA[
            go_manager_reject: f.go_manager_reject, employee_email: f.employee_email, manager_comment: f.manager_comment;
            if ((go_manager_reject.value as Integer) == 1) {
            sendEmail([employee_email.value], "Leave Request Rejected by Manager", "Your leave request was rejected by your manager. Comment: ${manager_comment.value}")
            async.run { assignTask("submit_request"); finishTask("submit_request") }
            } else {
            async.run { assignTask("hr_review"); finishTask("hr_review") }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>hr_review</id>
    <x>496</x>
    <y>208</y>
    <label>HR Review</label>
    <icon>how_to_reg</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>hr</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>hr_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>HR Officer Decision</title>
      <dataRef>
        <id>hr_comment</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>leave_type</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>start_date</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>end_date</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>2</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>reason</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>manager_comment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>5</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>hr_finish</id>
      <actions phase="pre">
        <action id="7">
<![CDATA[
            go_hr_approve: f.go_hr_approve, go_hr_reject: f.go_hr_reject, status: f.status;
            // Approve if comment starts with "APPROVE", else reject
            def comment = (f.hr_comment.value ?: "").trim().toLowerCase()
            if (comment.startsWith("approve")) {
            change go_hr_approve value { 1 }; change go_hr_reject value { 0 };
            change status value { "approved" }
            } else {
            change go_hr_approve value { 0 }; change go_hr_reject value { 1 };
            change status value { "hr_rejected" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="8">
<![CDATA[
            go_hr_reject: f.go_hr_reject, employee_email: f.employee_email, hr_comment: f.hr_comment;
            if ((go_hr_reject.value as Integer) == 1) {
            sendEmail([employee_email.value], "Leave Request Rejected by HR", "Your leave request was rejected by HR. Comment: ${hr_comment.value}")
            async.run { assignTask("submit_request"); finishTask("submit_request") }
            } else {
            async.run { assignTask("final_approval"); finishTask("final_approval") }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>final_approval</id>
    <x>688</x>
    <y>208</y>
    <label>Leave Approved</label>
    <icon>check_circle</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>final_finish</id>
      <actions phase="post">
        <action id="9">
<![CDATA[
            employee_email: f.employee_email, leave_type: f.leave_type, start_date: f.start_date, end_date: f.end_date;
            sendEmail([employee_email.value], "Leave Request Approved", "Your leave request (${leave_type.value}) from ${start_date.value} to ${end_date.value} has been approved.")
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>status_task</id>
    <x>304</x>
    <y>16</y>
    <label>Status</label>
    <icon>info</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>2</priority>
    <roleRef>
      <id>employee</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>status_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Status View</title>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
