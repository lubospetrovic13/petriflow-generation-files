<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>public_request</id>
  <version>1.0.0</version>
  <initials>REQ</initials>
  <title>Public Request Form</title>
  <icon>assignment</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>true</anonymousRole>
  <transitionRole>false</transitionRole>

  <caseEvents>
    <event type="create"><id>on_create</id>
      <actions phase="post"><action id="1"><![CDATA[
        status: f.status;
        change status value { "Submitted" }
      ]]></action></actions>
    </event>
  </caseEvents>

  <role><id>desk</id><title>Registration Desk</title></role>
  <role><id>legal</id><title>Legal</title></role>
  <role><id>pr</id><title>PR</title></role>

  <data type="text"><id>name</id><title>Name</title></data>
  <data type="text"><id>surname</id><title>Surname</title></data>
  <data type="text"><id>email</id><title>Email</title></data>
  <data type="text"><id>phone</id><title>Phone</title></data>
  <data type="text"><id>request_text</id><title>Request Description</title>
    <component><name>textarea</name></component>
  </data>
  <data type="file"><id>attachment</id><title>Attachment</title>
    <component><name>preview</name></component>
  </data>
  <data type="enumeration_map"><id>route</id><title>Route To</title>
    <options>
      <option key="legal">Legal</option>
      <option key="pr">PR</option>
    </options>
  </data>
  <data type="number"><id>to_legal</id><title>To Legal</title><init>0</init></data>
  <data type="number"><id>to_pr</id><title>To PR</title><init>0</init></data>
  <data type="text"><id>legal_statement</id><title>Lawyer Statement</title>
    <component><name>textarea</name></component>
  </data>
  <data type="text"><id>pr_answer</id><title>PR Answer</title>
    <component><name>textarea</name></component>
  </data>
  <data type="text"><id>status</id><title>Status</title></data>
  <data type="taskRef"><id>status_view</id><title>Status View</title><init>status_task</init></data>

  <transition>
    <id>submit</id><x>208</x><y>208</y><label>Submit Request</label>
    <icon>send</icon><assignPolicy>auto</assignPolicy><priority>1</priority>
    <roleRef><id>anonymous</id><logic><perform>true</perform></logic></roleRef>
    <dataGroup>
      <id>submit_group</id><cols>2</cols><layout>grid</layout><title>Submit Request</title>
      <dataRef>
        <id>name</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>0</x><y>0</y><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>surname</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>1</x><y>0</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>email</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>0</x><y>1</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>phone</id>
        <logic><behavior>editable</behavior></logic>
        <layout><x>1</x><y>1</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>0</x><y>2</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic><behavior>editable</behavior></logic>
        <layout><x>0</x><y>3</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
    </dataGroup>
  </transition>

  <transition>
    <id>desk_review</id><x>400</x><y>208</y><label>Desk Review</label>
    <icon>assignment_ind</icon><assignPolicy>auto</assignPolicy><priority>1</priority>
    <roleRef><id>desk</id><logic><perform>true</perform></logic></roleRef>
    <dataGroup>
      <id>desk_group</id><cols>2</cols><layout>grid</layout><title>Desk Review</title>
      <dataRef>
        <id>name</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>0</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>surname</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>1</x><y>0</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>email</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>1</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>phone</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>1</x><y>1</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>2</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>3</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>route</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>0</x><y>4</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
    </dataGroup>
    <event type="finish"><id>desk_finish</id>
      <actions phase="pre"><action id="2"><![CDATA[
        to_legal: f.to_legal, to_pr: f.to_pr, route: f.route, status: f.status;
        if (route.value == "legal") {
          change to_legal value { 1 }; change to_pr value { 0 };
          change status value { "In Legal Review" }
        } else {
          change to_legal value { 0 }; change to_pr value { 1 };
          change status value { "In PR Review" }
        }
      ]]></action></actions>
    </event>
  </transition>

  <transition>
    <id>legal_review</id><x>592</x><y>112</y><label>Legal Review</label>
    <icon>gavel</icon><assignPolicy>auto</assignPolicy><priority>1</priority>
    <roleRef><id>legal</id><logic><perform>true</perform></logic></roleRef>
    <dataGroup>
      <id>legal_group</id><cols>2</cols><layout>grid</layout><title>Legal Review</title>
      <dataRef>
        <id>request_text</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>0</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>1</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>0</x><y>2</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
    </dataGroup>
    <event type="finish"><id>legal_finish</id>
      <actions phase="pre"><action id="3"><![CDATA[
        status: f.status;
        change status value { "In PR Review" }
      ]]></action></actions>
    </event>
  </transition>

  <transition>
    <id>pr_review</id><x>784</x><y>208</y><label>PR Review</label>
    <icon>campaign</icon><assignPolicy>auto</assignPolicy><priority>1</priority>
    <roleRef><id>pr</id><logic><perform>true</perform></logic></roleRef>
    <dataGroup>
      <id>pr_group</id><cols>2</cols><layout>grid</layout><title>PR Review</title>
      <dataRef>
        <id>request_text</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>0</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>1</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>2</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>pr_answer</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>0</x><y>3</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
    </dataGroup>
    <event type="finish"><id>pr_finish</id>
      <actions phase="pre"><action id="4"><![CDATA[
        status: f.status;
        change status value { "Answered" }
      ]]></action></actions>
    </event>
  </transition>

  <transition>
    <id>status_task</id><x>400</x><y>16</y><label>Status View</label>
    <icon>visibility</icon><assignPolicy>auto</assignPolicy><priority>2</priority>
    <roleRef><id>anonymous</id><logic><perform>true</perform></logic></roleRef>
    <dataGroup>
      <id>status_group</id><cols>2</cols><layout>grid</layout><title>Status</title>
      <dataRef>
        <id>status</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>0</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>1</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>2</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>3</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>pr_answer</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>4</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
    </dataGroup>
  </transition>

  <place><id>start</id><x>112</x><y>208</y><label>Start</label><tokens>1</tokens><static>false</static></place>
  <place><id>p0</id><x>304</x><y>208</y><label>Submitted</label><tokens>0</tokens><static>false</static></place>
  <place><id>p_legal</id><x>592</x><y>112</y><label>Legal Queue</label><tokens>0</tokens><static>false</static></place>
  <place><id>p_pr</id><x>592</x><y>304</y><label>PR Queue</label><tokens>0</tokens><static>false</static></place>
  <place><id>p_status</id><x>304</x><y>16</y><label>Status Place</label><tokens>0</tokens><static>false</static></place>
  <place><id>done</id><x>976</x><y>208</y><label>Done</label><tokens>0</tokens><static>false</static></place>

  <arc><id>a1</id><type>regular</type><sourceId>start</sourceId><destinationId>submit</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a2</id><type>regular</type><sourceId>submit</sourceId><destinationId>p0</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a3</id><type>regular</type><sourceId>p0</sourceId><destinationId>desk_review</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a4</id><type>regular</type><sourceId>desk_review</sourceId><destinationId>p_legal</destinationId><multiplicity>0</multiplicity><reference>to_legal</reference></arc>
  <arc><id>a5</id><type>regular</type><sourceId>desk_review</sourceId><destinationId>p_pr</destinationId><multiplicity>0</multiplicity><reference>to_pr</reference></arc>
  <arc><id>a6</id><type>regular</type><sourceId>p_legal</sourceId><destinationId>legal_review</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a7</id><type>regular</type><sourceId>legal_review</sourceId><destinationId>p_pr</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a8</id><type>regular</type><sourceId>p_pr</sourceId><destinationId>pr_review</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a9</id><type>regular</type><sourceId>pr_review</sourceId><destinationId>done</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a10</id><type>regular</type><sourceId>submit</sourceId><destinationId>p_status</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a11</id><type>read</type><sourceId>p_status</sourceId><destinationId>status_task</destinationId><multiplicity>1</multiplicity></arc>
</document>
