<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>procurement_workflow</id>
  <version>1.0.0</version>
  <initials>PRC</initials>
  <title>Internal Procurement Workflow</title>
  <icon>shopping_cart</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <role>
    <id>legal_reviewer</id>
    <title>Legal Reviewer</title>
  </role>
  <role>
    <id>finance_reviewer</id>
    <title>Finance Reviewer</title>
  </role>
  <role>
    <id>procurement_manager</id>
    <title>Procurement Manager</title>
  </role>
  <role>
    <id>system</id>
    <title>System</title>
  </role>
  <!-- DATA FIELDS -->
  <data type="text">
    <id>vendor_name</id>
    <title>Vendor Name</title>
    <placeholder>Enter vendor name</placeholder>
  </data>
  <data type="number">
    <id>amount</id>
    <title>Amount</title>
    <component>
      <name>currency</name>
    </component>
  </data>
  <data type="enumeration_map">
    <id>category</id>
    <title>Category</title>
    <options>
      <option key="software">Software</option>
      <option key="hardware">Hardware</option>
      <option key="services">Services</option>
      <option key="other">Other</option>
    </options>
  </data>
  <data type="text">
    <id>justification</id>
    <title>Business Justification</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="text">
    <id>description</id>
    <title>Detailed Description</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="file">
    <id>attachment</id>
    <title>Supporting Document</title>
  </data>
  <data type="text">
    <id>status</id>
    <title>Current Status</title>
    <init>Draft</init>
  </data>
  <!-- Legal Review Data -->
  <data type="enumeration_map">
    <id>legal_decision</id>
    <title>Legal Compliance Decision</title>
    <options>
      <option key="approve">Approve</option>
      <option key="reject">Reject</option>
    </options>
  </data>
  <data type="text">
    <id>legal_comment</id>
    <title>Legal Reviewer Comment</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <!-- Finance Review Data -->
  <data type="enumeration_map">
    <id>finance_decision</id>
    <title>Finance Budget Decision</title>
    <options>
      <option key="approve">Approve</option>
      <option key="reject">Reject</option>
    </options>
  </data>
  <data type="text">
    <id>finance_comment</id>
    <title>Finance Reviewer Comment</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <!-- Manager Review Data -->
  <data type="enumeration_map">
    <id>manager_decision</id>
    <title>Final Decision</title>
    <options>
      <option key="issue">Issue PO</option>
      <option key="reject">Reject PO</option>
    </options>
  </data>
  <data type="text">
    <id>manager_comment</id>
    <title>Manager Comment</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <!-- Routing Flags -->
  <data type="number">
    <id>go_revise</id>
    <title>Go Revise</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_manager</id>
    <title>Go Manager</title>
    <init>0</init>
  </data>
  <!-- TRANSITIONS -->
  <transition>
    <id>submit</id>
    <x>112</x>
    <y>208</y>
    <label>Submit Purchase Order</label>
    <icon>send</icon>
    <assignPolicy>auto</assignPolicy>
    <dataGroup>
      <id>dg_submit</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>PO Details</title>
      <dataRef>
        <id>vendor_name</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>amount</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>category</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>justification</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>submit_finish</id>
      <actions phase="pre">
        <action id="1">status: f.status;
                    change status value { "In Parallel Review" }</action>
      </actions>
      <actions phase="post">
        <action id="2">async.run {
                        assignTask("split_sys");
                        finishTask("split_sys");
                    }</action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>split_sys</id>
    <x>304</x>
    <y>208</y>
    <label>Split to Reviews</label>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
  </transition>
  <transition>
    <id>legal_review</id>
    <x>496</x>
    <y>112</y>
    <label>Legal Compliance Review</label>
    <icon>gavel</icon>
    <roleRef>
      <id>legal_reviewer</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_legal</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Legal Review</title>
      <dataRef>
        <id>vendor_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>amount</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_decision</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_comment</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <transition>
    <id>finance_review</id>
    <x>496</x>
    <y>304</y>
    <label>Finance Budget Review</label>
    <icon>account_balance_wallet</icon>
    <roleRef>
      <id>finance_reviewer</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_finance</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Finance Review</title>
      <dataRef>
        <id>vendor_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>amount</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>finance_decision</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>finance_comment</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <transition>
    <id>router_sys</id>
    <x>880</x>
    <y>208</y>
    <label>Evaluate Reviews</label>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>router_finish</id>
      <actions phase="pre">
        <action id="3">legal_decision: f.legal_decision,
                    finance_decision: f.finance_decision,
                    go_revise: f.go_revise,
                    go_manager: f.go_manager,
                    status: f.status;

                    if (legal_decision.value == "reject" || finance_decision.value == "reject") {
                        change go_revise value { 1 };
                        change go_manager value { 0 };
                        change status value { "Rejected - Revision Required" };
                    } else {
                        change go_revise value { 0 };
                        change go_manager value { 1 };
                        change status value { "Pending Final Approval" };
                    }</action>
      </actions>
      <actions phase="post">
        <action id="4">legal_decision: f.legal_decision,
                    finance_decision: f.finance_decision,
                    legal_comment: f.legal_comment,
                    finance_comment: f.finance_comment;

                    if (legal_decision.value == "reject" || finance_decision.value == "reject") {
                        def body = "Your PO has been rejected during review.\n\nLegal: ${legal_decision.value} - ${legal_comment.value}\nFinance: ${finance_decision.value} - ${finance_comment.value}";
                        sendEmail([userService.loggedOrSystem.email], "PO Revision Required", body);
                    }</action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>revise</id>
    <x>688</x>
    <y>400</y>
    <label>Revise and Resubmit</label>
    <icon>edit</icon>
    <dataGroup>
      <id>dg_revise</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Revision</title>
      <dataRef>
        <id>legal_comment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>finance_comment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>vendor_name</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>amount</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>2</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>justification</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>revise_finish</id>
      <actions phase="pre">
        <action id="5">status: f.status;
                    change status value { "Resubmitted" }</action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>manager_review</id>
    <x>1072</x>
    <y>208</y>
    <label>Procurement Manager Decision</label>
    <icon>assignment_turned_in</icon>
    <roleRef>
      <id>procurement_manager</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_manager</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Final Approval</title>
      <dataRef>
        <id>legal_comment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>finance_comment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>manager_decision</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>manager_comment</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>manager_finish</id>
      <actions phase="pre">
        <action id="6">manager_decision: f.manager_decision,
                    status: f.status;
                    if (manager_decision.value == "issue") {
                        change status value { "PO Issued" };
                    } else {
                        change status value { "PO Rejected by Manager" };
                    }</action>
      </actions>
      <actions phase="post">
        <action id="7">manager_decision: f.manager_decision,
                    manager_comment: f.manager_comment;
                    if (manager_decision.value == "issue") {
                        sendEmail([userService.loggedOrSystem.email], "PO Confirmation", "Your Purchase Order has been issued.\n\nComment: ${manager_comment.value}");
                    }</action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>status_view</id>
    <x>304</x>
    <y>16</y>
    <label>My Request Status</label>
    <icon>visibility</icon>
    <priority>2</priority>
    <dataGroup>
      <id>dg_status</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Current Status</title>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_comment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>finance_comment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>manager_comment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <!-- PLACES -->
  <place>
    <id>p_start</id>
    <x>0</x>
    <y>208</y>
    <label>Start</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_pending</id>
    <x>208</x>
    <y>208</y>
    <label>Pending Review</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_legal_q</id>
    <x>400</x>
    <y>112</y>
    <label>Legal Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_finance_q</id>
    <x>400</x>
    <y>304</y>
    <label>Finance Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_join</id>
    <x>688</x>
    <y>208</y>
    <label>Reviews Completed</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_revise</id>
    <x>880</x>
    <y>400</y>
    <label>Revision Needed</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_manager_q</id>
    <x>976</x>
    <y>208</y>
    <label>Manager Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_end</id>
    <x>1264</x>
    <y>208</y>
    <label>Finished</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_status</id>
    <x>112</x>
    <y>16</y>
    <label>Status Tracking</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <!-- ARCS -->
  <arc>
    <id>a1</id>
    <type>regular</type>
    <sourceId>p_start</sourceId>
    <destinationId>submit</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2</id>
    <type>regular</type>
    <sourceId>submit</sourceId>
    <destinationId>p_pending</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3</id>
    <type>regular</type>
    <sourceId>submit</sourceId>
    <destinationId>p_status</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a4</id>
    <type>read</type>
    <sourceId>p_status</sourceId>
    <destinationId>status_view</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a5</id>
    <type>regular</type>
    <sourceId>p_pending</sourceId>
    <destinationId>split_sys</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a6</id>
    <type>regular</type>
    <sourceId>split_sys</sourceId>
    <destinationId>p_legal_q</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a7</id>
    <type>regular</type>
    <sourceId>split_sys</sourceId>
    <destinationId>p_finance_q</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a8</id>
    <type>regular</type>
    <sourceId>p_legal_q</sourceId>
    <destinationId>legal_review</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a9</id>
    <type>regular</type>
    <sourceId>p_finance_q</sourceId>
    <destinationId>finance_review</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a10</id>
    <type>regular</type>
    <sourceId>legal_review</sourceId>
    <destinationId>p_join</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a11</id>
    <type>regular</type>
    <sourceId>finance_review</sourceId>
    <destinationId>p_join</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a12</id>
    <type>regular</type>
    <sourceId>p_join</sourceId>
    <destinationId>router_sys</destinationId>
    <multiplicity>2</multiplicity>
  </arc>
  <arc>
    <id>a13</id>
    <type>regular</type>
    <sourceId>router_sys</sourceId>
    <destinationId>p_revise</destinationId>
    <multiplicity>0</multiplicity>
    <reference>go_revise</reference>
  </arc>
  <arc>
    <id>a14</id>
    <type>regular</type>
    <sourceId>router_sys</sourceId>
    <destinationId>p_manager_q</destinationId>
    <multiplicity>0</multiplicity>
    <reference>go_manager</reference>
  </arc>
  <arc>
    <id>a15</id>
    <type>regular</type>
    <sourceId>p_revise</sourceId>
    <destinationId>revise</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a16</id>
    <type>regular</type>
    <sourceId>revise</sourceId>
    <destinationId>p_pending</destinationId>
    <multiplicity>1</multiplicity>
    <breakpoint>
      <x>688</x>
      <y>500</y>
    </breakpoint>
    <breakpoint>
      <x>208</x>
      <y>500</y>
    </breakpoint>
  </arc>
  <arc>
    <id>a17</id>
    <type>regular</type>
    <sourceId>p_manager_q</sourceId>
    <destinationId>manager_review</destinationId>
    <multiplicity>1</multiplicity>
