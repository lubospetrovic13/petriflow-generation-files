    <x>304</x>
    <y>208</y>
    <label>Validation</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_manager</id>
    <x>496</x>
    <y>208</y>
    <label>Pending Manager</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_hr</id>
    <x>880</x>
    <y>208</y>
    <label>Pending HR</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_approved</id>
    <x>1072</x>
    <y>208</y>
    <label>Approved</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_rejected</id>
    <x>1072</x>
    <y>304</y>
    <label>Rejected</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_changes</id>
    <x>688</x>
    <y>400</y>
    <label>Changes Requested</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_delegate</id>
