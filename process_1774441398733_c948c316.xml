<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>leave_request</id>
  <version>1.0.0</version>
  <initials>LRQ</initials>
  <title>Leave Request Approval</title>
  <icon>event</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <!-- ROLES -->
  <role>
    <id>employee</id>
    <title>Employee</title>
  </role>
  <role>
    <id>manager</id>
    <title>Manager</title>
  </role>
  <role>
    <id>hr</id>
    <title>HR</title>
  </role>
  <!-- DATA FIELDS -->
  <data type="enumeration_map">
    <id>leave_type</id>
    <title>Leave Type</title>
    <options>
      <option>
        <key>annual</key>
        <value>Annual Leave</value>
      </option>
      <option>
        <key>sick</key>
        <value>Sick Leave</value>
      </option>
      <option>
        <key>unpaid</key>
        <value>Unpaid Leave</value>
      </option>
    </options>
    <init>annual</init>
  </data>
  <data type="date">
    <id>start_date</id>
    <title>Start Date</title>
  </data>
  <data type="date">
    <id>end_date</id>
    <title>End Date</title>
  </data>
  <data type="text">
    <id>reason</id>
    <title>Reason</title>
  </data>
  <data type="text">
    <id>manager_comment</id>
    <title>Manager Comment</title>
  </data>
  <data type="text">
    <id>hr_comment</id>
    <title>HR Comment</title>
  </data>
  <data type="enumeration_map">
    <id>manager_decision</id>
    <title>Manager Decision</title>
    <options>
      <option>
        <key>approve</key>
        <value>Approve</value>
      </option>
      <option>
        <key>reject</key>
        <value>Reject</value>
      </option>
    </options>
    <init>approve</init>
  </data>
  <data type="enumeration_map">
    <id>hr_decision</id>
    <title>HR Decision</title>
    <options>
      <option>
        <key>approve</key>
        <value>Approve</value>
      </option>
      <option>
        <key>reject</key>
        <value>Reject</value>
      </option>
    </options>
    <init>approve</init>
  </data>
  <data type="text">
    <id>status</id>
    <title>Status</title>
    <value>Draft</value>
  </data>
  <data type="text">
    <id>manager_approver</id>
    <title>Manager Approver</title>
  </data>
  <data type="dateTime">
    <id>manager_decision_time</id>
    <title>Manager Decision Time</title>
  </data>
  <data type="text">
    <id>hr_approver</id>
    <title>HR Approver</title>
  </data>
  <data type="dateTime">
    <id>hr_decision_time</id>
    <title>HR Decision Time</title>
  </data>
  <!-- TRANSITIONS -->
  <transition>
    <id>submit_request</id>
    <x>208</x>
    <y>208</y>
    <label>Submit Leave Request</label>
    <icon>send</icon>
    <priority>1</priority>
    <roleRef>
      <id>employee</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>submit_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Leave Request</title>
      <dataRef>
        <id>leave_type</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>start_date</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>end_date</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>reason</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>ev_submit_finish</id>
      <actions phase="pre">
        <action id="1">
<![CDATA[
            status: f.status;
            change status value { "Pending Manager Approval" }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>manager_review</id>
    <x>496</x>
    <y>208</y>
    <label>Manager Review</label>
    <icon>assignment_ind</icon>
    <priority>1</priority>
    <roleRef>
      <id>manager</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>manager_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Manager Review</title>
      <dataRef>
        <id>manager_decision</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>manager_comment</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>optional</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>ev_manager_finish</id>
      <actions phase="pre">
        <action id="2">
<![CDATA[
            manager_decision: f.manager_decision, status: f.status, manager_approver: f.manager_approver, manager_decision_time: f.manager_decision_time;
            if ((manager_decision.value as Set).contains("approve")) {
            change status value { "Pending HR Approval" }
            } else {
            change status value { "Rejected by Manager" }
            }
            change manager_approver value { userService.loggedOrSystem.email }
            change manager_decision_time value { java.time.LocalDateTime.now() }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>hr_review</id>
    <x>784</x>
    <y>208</y>
    <label>HR Review</label>
    <icon>supervisor_account</icon>
    <priority>1</priority>
    <roleRef>
      <id>hr</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>hr_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>HR Review</title>
      <dataRef>
        <id>hr_decision</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>hr_comment</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>optional</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>ev_hr_finish</id>
      <actions phase="pre">
        <action id="3">
<![CDATA[
            hr_decision: f.hr_decision, status: f.status, hr_approver: f.hr_approver, hr_decision_time: f.hr_decision_time;
            if ((hr_decision.value as Set).contains("approve")) {
            change status value { "Approved" }
            } else {
            change status value { "Rejected by HR" }
            }
            change hr_approver value { userService.loggedOrSystem.email }
            change hr_decision_time value { java.time.LocalDateTime.now() }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- PLACES -->
  <place>
    <id>start</id>
    <x>112</x>
    <y>208</y>
    <label>Start</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p0</id>
    <x>304</x>
    <y>208</y>
    <label>Pending Manager</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>reviewed</id>
    <x>688</x>
    <y>208</y>
    <label>Pending HR</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>approved</id>
    <x>1072</x>
    <y>112</y>
    <label>Approved</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>rejected_manager</id>
    <x>1072</x>
    <y>304</y>
    <label>Rejected by Manager</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>rejected_hr</id>
    <x>1264</x>
    <y>304</y>
    <label>Rejected by HR</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <!-- ARCS -->
  <arc>
    <id>a1</id>
    <type>regular</type>
    <sourceId>start</sourceId>
    <destinationId>submit_request</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2</id>
    <type>regular</type>
    <sourceId>submit_request</sourceId>
    <destinationId>p0</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3</id>
    <type>regular</type>
    <sourceId>p0</sourceId>
    <destinationId>manager_review</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a4</id>
    <type>regular</type>
    <sourceId>manager_review</sourceId>
    <destinationId>reviewed</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a5</id>
    <type>regular</type>
    <sourceId>manager_review</sourceId>
    <destinationId>rejected_manager</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a6</id>
    <type>regular</type>
    <sourceId>reviewed</sourceId>
    <destinationId>hr_review</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a7</id>
    <type>regular</type>
    <sourceId>hr_review</sourceId>
    <destinationId>approved</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a8</id>
    <type>regular</type>
    <sourceId>hr_review</sourceId>
    <destinationId>rejected_hr</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <!-- CASE EVENTS -->
  <caseEvents>
    <event type="create">
      <id>on_create</id>
      <actions phase="post">
        <action id="4">
<![CDATA[
            status: f.status;
            change status value { "Draft" }
            ]]>
        </action>
      </actions>
    </event>
  </caseEvents>
</document>