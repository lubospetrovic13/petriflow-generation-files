<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>email_gemini_triage</id>
  <version>1.0.0</version>
  <initials>EGT</initials>
  <title>Email Gemini AI Triage and Review</title>
  <icon>mail_lock</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <role>
    <id>reviewer</id>
    <title>Reviewer</title>
  </role>
  <role>
    <id>system</id>
    <title>System</title>
  </role>
  <data type="text">
    <id>sender_name</id>
    <title>Sender Name</title>
  </data>
  <data type="text">
    <id>sender_email</id>
    <title>Sender Email Address</title>
  </data>
  <data type="text">
    <id>subject</id>
    <title>Subject</title>
  </data>
  <data type="text">
    <id>email_body</id>
    <title>Email Body</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="file">
    <id>attachment</id>
    <title>Attachment</title>
  </data>
  <data type="text">
    <id>api_key</id>
    <title>Gemini API Key</title>
    <value>YOUR_GEMINI_API_KEY</value>
  </data>
  <data type="enumeration_map">
    <id>ai_category</id>
    <title>AI Classification</title>
    <options>
      <option key="complaint">Complaint</option>
      <option key="inquiry">Inquiry</option>
      <option key="order">Order</option>
      <option key="spam">Spam</option>
      <option key="other">Other</option>
    </options>
  </data>
  <data type="text">
    <id>extracted_entities</id>
    <title>Extracted Entities</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="text">
    <id>response_draft</id>
    <title>Suggested Response Draft</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="enumeration_map">
    <id>final_action</id>
    <title>Final Action</title>
    <options>
      <option key="reply">Reply</option>
      <option key="forward">Forward</option>
      <option key="archive">Archive</option>
      <option key="escalate">Escalate</option>
    </options>
  </data>
  <transition>
    <id>submit_email</id>
    <x>112</x>
    <y>208</y>
    <label>Submit Incoming Email</label>
    <icon>file_upload</icon>
    <assignPolicy>auto</assignPolicy>
    <dataGroup>
      <id>dg_submit</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Email Details</title>
      <dataRef>
        <id>sender_name</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>sender_email</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>subject</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>email_body</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>submit_finish</id>
      <actions phase="post">
        <action id="1">
<![CDATA[
            async.run {
            assignTask("ai_analysis")
            finishTask("ai_analysis")
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>ai_analysis</id>
    <x>304</x>
    <y>208</y>
    <label>Gemini Analysis</label>
    <icon>auto_awesome</icon>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>ai_finish</id>
      <actions phase="post">
        <action id="2">
<![CDATA[
            api_key: f.api_key, subject: f.subject, email_body: f.email_body;
            async.run {
            def promptText = "Analyze this email. Subject: ${subject.value}. Body: ${email_body.value}. " +
            "Return a JSON object with exactly these keys: 'category' (must be one of: complaint, inquiry, order, spam, other), " +
            "'entities' (string listing names, dates, amounts found), and 'draft' (a professional reply draft)."
            
            def url = "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${api_key.value}"
            def conn = (java.net.HttpURLConnection) new java.net.URL(url).openConnection()
            conn.setRequestMethod("POST")
            conn.setRequestProperty("Content-Type", "application/json")
            conn.setDoOutput(true)
            conn.setConnectTimeout(15000)
            conn.setReadTimeout(60000)
            
            def payload = [
            contents: [[parts: [[text: promptText]]]],
            generationConfig: [
            responseMimeType: "application/json"
            ]
            ]
            conn.outputStream.write(groovy.json.JsonOutput.toJson(payload).getBytes("UTF-8"))
            
            def responseBody = ""
            try { responseBody = conn.inputStream.getText("UTF-8") }
            catch (e) { responseBody = conn.errorStream?.getText("UTF-8") ?: '{"error":"unreachable"}' }
            
            def json = new groovy.json.JsonSlurper().parseText(responseBody)
            def content = json?.candidates?.getAt(0)?.content?.parts?.getAt(0)?.text ?: "{}"
            def data = new groovy.json.JsonSlurper().parseText(content)
            
            def tReview = findTask { it.transitionId.eq("review_email").and(it.caseId.eq(useCase.stringId)) }
            if (tReview) {
            setData(tReview, [
            ai_category: [value: data.category ?: "other", type: "enumeration_map"],
            extracted_entities: [value: data.entities ?: "None found", type: "text"],
            response_draft: [value: data.draft ?: "", type: "text"]
            ])
            }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>review_email</id>
    <x>496</x>
    <y>208</y>
    <label>Review and Action</label>
    <icon>rate_review</icon>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>reviewer</id>
      <logic>
