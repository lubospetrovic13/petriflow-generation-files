<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>public_request_process</id>
  <version>1.0.0</version>
  <initials>PRP</initials>
  <title>Public Request Management</title>
  <icon>public</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>true</anonymousRole>
  <transitionRole>false</transitionRole>
  <role>
    <id>registration_desk</id>
    <title>Registration Desk</title>
  </role>
  <role>
    <id>legal_department</id>
    <title>Legal Department</title>
  </role>
  <role>
    <id>pr_department</id>
    <title>PR Department</title>
  </role>
  <data type="text">
    <id>name</id>
    <title>Name</title>
  </data>
  <data type="text">
    <id>surname</id>
    <title>Surname</title>
  </data>
  <data type="text">
    <id>email</id>
    <title>Email</title>
    <placeholder>example@domain.com</placeholder>
  </data>
  <data type="text">
    <id>phone</id>
    <title>Phone Number</title>
  </data>
  <data type="text">
    <id>request_description</id>
    <title>Request Description</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="file">
    <id>attachment</id>
    <title>Optional Attachment</title>
  </data>
  <data type="enumeration_map">
    <id>route_selection</id>
    <title>Route To</title>
    <options>
      <option key="legal">Legal Department</option>
      <option key="pr">PR Department (Direct)</option>
    </options>
  </data>
  <data type="number">
    <id>to_legal</id>
    <title>To Legal</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>to_pr</id>
    <title>To PR</title>
    <init>0</init>
  </data>
  <data type="text">
    <id>legal_statement</id>
    <title>Legal Statement</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="text">
    <id>final_answer</id>
    <title>Final Answer to Submitter</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="text">
    <id>status</id>
    <title>Current Status</title>
    <init>Submitted</init>
  </data>
  <transition>
    <id>submit_request</id>
    <x>112</x>
    <y>208</y>
    <label>Submit Request</label>
    <icon>send</icon>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>anonymous</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>submit_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Your Request</title>
      <dataRef>
        <id>name</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>surname</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>email</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>phone</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>request_description</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>submit_finish</id>
      <actions phase="pre">
        <action id="1">
<![CDATA[
            status: f.status;
            change status value { "Received and Awaiting Review" }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>review_request</id>
    <x>304</x>
    <y>208</y>
    <label>Review and Route</label>
    <icon>assignment_ind</icon>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>registration_desk</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>review_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Internal Review</title>
      <dataRef>
        <id>name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>surname</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>request_description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>route_selection</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>review_finish</id>
      <actions phase="pre">
        <action id="2">
<![CDATA[
            route: f.route_selection, to_legal: f.to_legal, to_pr: f.to_pr, status: f.status;
            if (route.value == "legal") {
            change to_legal value { 1 };
            change to_pr value { 0 };
            change status value { "Under Legal Review" };
            } else {
            change to_legal value { 0 };
            change to_pr value { 1 };
            change status value { "Preparing PR Response" };
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>legal_action</id>
    <x>496</x>
    <y>112</y>
    <label>Write Legal Statement</label>
    <icon>gavel</icon>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>legal_department</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>legal_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Legal Analysis</title>
      <dataRef>
        <id>request_description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>legal_finish</id>
      <actions phase="pre">
        <action id="3">
<![CDATA[
            status: f.status;
            change status value { "Legal Review Complete - Preparing PR Response" }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>pr_action</id>
    <x>688</x>
    <y>208</y>
    <label>Final PR Response</label>
    <icon>chat</icon>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>pr_department</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>pr_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Public Relations Response</title>
      <dataRef>
        <id>request_description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>final_answer</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>pr_finish</id>
      <actions phase="pre">
        <action id="4">
<![CDATA[
            status: f.status, t_status: t.status_view, final_answer: f.final_answer;
            change status value { "Completed" };
            make final_answer, visible on t_status when { true };
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>status_view</id>
    <x>304</x>
    <y>16</y>
    <label>Request Status</label>
    <icon>info</icon>
    <priority>2</priority>
    <roleRef>
      <id>anonymous</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>status_group</id>
      <cols>1</cols>
      <layout>grid</layout>
      <title>Current Status of Your Request</title>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>final_answer</id>
        <logic>
          <behavior>hidden</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <place>
    <id>p_start</id>
    <x>16</x>
    <y>208</y>
    <label>Start</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_review</id>
    <x>208</x>
    <y>208</y>
    <label>Review Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_legal</id>
    <x>400</x>
    <y>112</y>
    <label>Legal Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_pr</id>
    <x>592</x>
    <y>208</y>
    <label>PR Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_status</id>
    <x>208</x>
    <y>16</y>
    <label>Status Active</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_done</id>
    <x>784</x>
    <y>208</y>
    <label>Finished</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <arc>
    <id>a1</id>
    <type>regular</type>
    <sourceId>p_start</sourceId>
    <destinationId>submit_request</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2</id>
    <type>regular</type>
    <sourceId>submit_request</sourceId>
    <destinationId>p_review</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3</id>
    <type>regular</type>
    <sourceId>submit_request</sourceId>
    <destinationId>p_status</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a4</id>
    <type>read</type>
    <sourceId>p_status</sourceId>
    <destinationId>status_view</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a5</id>
    <type>regular</type>
    <sourceId>p_review</sourceId>
    <destinationId>review_request</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a6</id>
    <type>regular</type>
    <sourceId>review_request</sourceId>
    <destinationId>p_legal</destinationId>
    <multiplicity>0</multiplicity>
    <reference>to_legal</reference>
  </arc>
  <arc>
    <id>a7</id>
    <type>regular</type>
    <sourceId>review_request</sourceId>
    <destinationId>p_pr</destinationId>
    <multiplicity>0</multiplicity>
    <reference>to_pr</reference>
  </arc>
  <arc>
    <id>a8</id>
    <type>regular</type>
    <sourceId>p_legal</sourceId>
    <destinationId>legal_action</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a9</id>
    <type>regular</type>
    <sourceId>legal_action</sourceId>
    <destinationId>p_pr</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a10</id>
    <type>regular</type>
    <sourceId>p_pr</sourceId>
    <destinationId>pr_action</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a11</id>
    <type>regular</type>
    <sourceId>pr_action</sourceId>
    <destinationId>p_done</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
</document>