<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>purchase_order_process</id>
  <version>1.0.0</version>
  <initials>PO</initials>
  <title>Purchase Order Process</title>
  <icon>assignment</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <!-- Roles -->
  <role>
    <id>requester</id>
    <title>Requester</title>
  </role>
  <role>
    <id>legal</id>
    <title>Legal</title>
  </role>
  <role>
    <id>finance</id>
    <title>Finance</title>
  </role>
  <!-- Data Fields -->
  <data type="number">
    <id>order_amount</id>
    <title>Order Amount</title>
  </data>
  <data type="text">
    <id>order_description</id>
    <title>Order Description</title>
  </data>
  <!-- Transitions -->
  <transition>
    <id>submit_order</id>
    <x>208</x>
    <y>208</y>
    <label>Submit Order</label>
    <icon>send</icon>
    <priority>1</priority>
    <roleRef>
      <id>requester</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>order_details</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Order Details</title>
      <dataRef>
        <id>order_amount</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>order_description</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <transition>
    <id>review_legal</id>
    <x>688</x>
    <y>112</y>
    <label>Review Legal</label>
    <icon>gavel</icon>
    <priority>1</priority>
    <roleRef>
      <id>legal</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
  </transition>
  <transition>
    <id>review_finance</id>
    <x>688</x>
    <y>304</y>
    <label>Review Finance</label>
    <icon>account_balance</icon>
    <priority>1</priority>
    <roleRef>
      <id>finance</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
  </transition>
  <transition>
    <id>finalize_order</id>
    <x>1120</x>
    <y>208</y>
    <label>Finalize Order</label>
    <icon>done</icon>
    <priority>1</priority>
    <roleRef>
      <id>requester</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
  </transition>
  <!-- Places -->
  <place>
    <id>start</id>
    <x>112</x>
    <y>208</y>
    <label>Start</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p0</id>
    <x>496</x>
    <y>208</y>
    <label>Pending Review</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>legal_p</id>
    <x>880</x>
    <y>112</y>
    <label>Legal Review</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>finance_p</id>
    <x>880</x>
    <y>304</y>
    <label>Finance Review</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>join</id>
    <x>1008</x>
    <y>208</y>
    <label>Join</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>done</id>
    <x>1264</x>
    <y>208</y>
    <label>Done</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <!-- Arcs -->
  <arc>
    <id>a1</id>
    <type>regular</type>
    <sourceId>start</sourceId>
    <destinationId>submit_order</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2</id>
    <type>regular</type>
    <sourceId>submit_order</sourceId>
    <destinationId>p0</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3</id>
    <type>regular</type>
    <sourceId>p0</sourceId>
    <destinationId>review_legal</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a4</id>
    <type>regular</type>
    <sourceId>p0</sourceId>
    <destinationId>review_finance</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a5</id>
    <type>regular</type>
    <sourceId>review_legal</sourceId>
    <destinationId>legal_p</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a6</id>
    <type>regular</type>
    <sourceId>review_finance</sourceId>
    <destinationId>finance_p</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a7</id>
    <type>regular</type>
    <sourceId>legal_p</sourceId>
    <destinationId>join</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a8</id>
    <type>regular</type>
    <sourceId>finance_p</sourceId>
    <destinationId>join</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a9</id>
    <type>regular</type>
    <sourceId>join</sourceId>
    <destinationId>finalize_order</destinationId>
    <multiplicity>2</multiplicity>
  </arc>
  <arc>
    <id>a10</id>
    <type>regular</type>
    <sourceId>finalize_order</sourceId>
    <destinationId>done</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <!-- Case Events -->
</document>