<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>purchase_order_parallel_review</id>
  <version>1.0.0</version>
  <initials>PO</initials>
  <title>Purchase Order with Parallel Legal and Finance Review</title>
  <icon>assignment</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <!-- ROLES -->
  <role>
    <id>finance</id>
    <title>Finance</title>
  </role>
  <role>
    <id>legal</id>
    <title>Legal</title>
  </role>
  <role>
    <id>requester</id>
    <title>Requester</title>
  </role>
  <role>
    <id>system</id>
    <title>System</title>
  </role>
  <!-- DATA FIELDS -->
  <data type="number">
    <id>amount</id>
    <title>Amount</title>
    <component>
      <name>currency</name>
    </component>
  </data>
  <data type="text">
    <id>description</id>
    <title>Description</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="text">
    <id>finance_comment</id>
    <title>Finance Review Comment</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="enumeration_map">
    <id>finance_decision</id>
    <title>Finance Decision</title>
    <options>
      <option key="approve">Approve</option>
      <option key="reject">Reject</option>
    </options>
  </data>
  <data type="text">
    <id>legal_comment</id>
    <title>Legal Review Comment</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="enumeration_map">
    <id>legal_decision</id>
    <title>Legal Decision</title>
    <options>
      <option key="approve">Approve</option>
      <option key="reject">Reject</option>
    </options>
  </data>
  <data type="text">
    <id>po_number</id>
    <title>PO Number</title>
  </data>
  <data type="text">
    <id>requester_email</id>
    <title>Requester Email</title>
  </data>
  <data type="text">
    <id>status</id>
    <title>Status</title>
  </data>
  <data type="text">
    <id>vendor</id>
    <title>Vendor</title>
  </data>
  <!-- TRANSITIONS -->
  <transition>
    <id>final_approval</id>
    <x>1264</x>
    <y>208</y>
    <label>Final Approval</label>
    <icon>check_circle</icon>
    <priority>1</priority>
    <roleRef>
      <id>requester</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>final_approval_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Final Approval</title>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>on_final_approval_finish</id>
      <actions phase="pre">
        <action id="1">
<![CDATA[
            status: f.status;
            change status value { "Approved" }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="2">
<![CDATA[
            requester_email: f.requester_email, status: f.status;
            sendEmail([requester_email.value], "Purchase Order Approved", "Your purchase order has been approved. Status: ${status.value}")
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>finance_review</id>
    <x>688</x>
    <y>304</y>
    <label>Finance Review</label>
    <icon>account_balance</icon>
    <priority>1</priority>
    <roleRef>
      <id>finance</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>finance_review_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Finance Review</title>
      <dataRef>
        <id>finance_decision</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>finance_comment</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>on_finance_review_finish</id>
      <actions phase="pre">
        <action id="3">
<![CDATA[
            finance_decision: f.finance_decision, status: f.status;
            if (finance_decision.value == "approve") {
            change status value { "Finance Approved" }
            } else {
            change status value { "Rejected by Finance" }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>finance_reject</id>
    <x>976</x>
    <y>400</y>
    <label>Finance Reject</label>
    <icon>cancel</icon>
    <priority>1</priority>
    <roleRef>
      <id>finance</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>finance_reject_group</id>
      <cols>1</cols>
      <layout>grid</layout>
      <title>Finance Rejection</title>
      <dataRef>
        <id>finance_comment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>on_finance_reject_finish</id>
      <actions phase="post">
        <action id="4">
<![CDATA[
            requester_email: f.requester_email, status: f.status;
            sendEmail([requester_email.value], "Purchase Order Rejected", "Your purchase order has been rejected by Finance. Status: ${status.value}")
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>legal_review</id>
    <x>688</x>
    <y>112</y>
    <label>Legal Review</label>
    <icon>gavel</icon>
    <priority>1</priority>
    <roleRef>
      <id>legal</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>legal_review_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Legal Review</title>
      <dataRef>
        <id>legal_decision</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_comment</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>on_legal_review_finish</id>
      <actions phase="pre">
        <action id="5">
<![CDATA[
            legal_decision: f.legal_decision, status: f.status;
            if (legal_decision.value == "approve") {
            change status value { "Legal Approved" }
            } else {
            change status value { "Rejected by Legal" }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>legal_reject</id>
    <x>976</x>
    <y>16</y>
    <label>Legal Reject</label>
    <icon>cancel</icon>
    <priority>1</priority>
    <roleRef>
      <id>legal</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>legal_reject_group</id>
      <cols>1</cols>
      <layout>grid</layout>
      <title>Legal Rejection</title>
      <dataRef>
        <id>legal_comment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>on_legal_reject_finish</id>
      <actions phase="post">
        <action id="6">
<![CDATA[
            requester_email: f.requester_email, status: f.status;
            sendEmail([requester_email.value], "Purchase Order Rejected", "Your purchase order has been rejected by Legal. Status: ${status.value}")
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>split</id>
    <x>496</x>
    <y>208</y>
    <label>Start Parallel Review</label>
    <icon>call_split</icon>
    <priority>1</priority>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
  </transition>
  <transition>
    <id>submit_order</id>
    <x>304</x>
    <y>208</y>
    <label>Submit Order</label>
    <icon>send</icon>
    <priority>1</priority>
    <roleRef>
      <id>requester</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>submit_order_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Purchase Order Submission</title>
      <dataRef>
        <id>po_number</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>amount</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>vendor</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>requester_email</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>on_submit_order_finish</id>
      <actions phase="pre">
        <action id="7">
<![CDATA[
            status: f.status;
            change status value { "Submitted" }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="8">
<![CDATA[
            async.run { assignTask("split"); finishTask("split") }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- PLACES -->
  <place>
    <id>approved</id>
    <x>1552</x>
    <y>208</y>
    <label>Approved</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>done_finance</id>
    <x>1072</x>
    <y>304</y>
    <label>Finance Done</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>done_legal</id>
    <x>1072</x>
    <y>112</y>
    <label>Legal Done</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>finance_p</id>
    <x>496</x>
    <y>304</y>
    <label>Finance Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>join</id>
    <x>1264</x>
    <y>208</y>
    <label>Both Reviews Done</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>legal_p</id>
    <x>496</x>
    <y>112</y>
    <label>Legal Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_split</id>
    <x>400</x>
    <y>208</y>
    <label>Pending Split</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>rejected</id>
    <x>1552</x>
    <y>16</y>
    <label>Rejected</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>start</id>
    <x>112</x>
    <y>208</y>
    <label>Start</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <!-- ARCS -->
  <arc>
    <id>a1_start_submit</id>
    <type>regular</type>
    <sourceId>start</sourceId>
    <destinationId>submit_order</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2_submit_psplit</id>
    <type>regular</type>
    <sourceId>submit_order</sourceId>
    <destinationId>p_split</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3_psplit_split</id>
    <type>regular</type>
    <sourceId>p_split</sourceId>
    <destinationId>split</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a4_split_legalp</id>
    <type>regular</type>
    <sourceId>split</sourceId>
    <destinationId>legal_p</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a5_split_financep</id>
    <type>regular</type>
    <sourceId>split</sourceId>
    <destinationId>finance_p</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a6_legalp_legalreview</id>
    <type>regular</type>
    <sourceId>legal_p</sourceId>
    <destinationId>legal_review</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a7_financep_financereview</id>
    <type>regular</type>
    <sourceId>finance_p</sourceId>
    <destinationId>finance_review</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a8_legalreview_donelegal</id>
    <type>regular</type>
    <sourceId>legal_review</sourceId>
    <destinationId>done_legal</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a9_financereview_donefinance</id>
    <type>regular</type>
    <sourceId>finance_review</sourceId>
    <destinationId>done_finance</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a10_donelegal_join</id>
    <type>regular</type>
    <sourceId>done_legal</sourceId>
    <destinationId>join</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a11_donefinance_join</id>
    <type>regular</type>
    <sourceId>done_finance</sourceId>
    <destinationId>join</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a12_join_finalapproval</id>
    <type>regular</type>
    <sourceId>join</sourceId>
    <destinationId>final_approval</destinationId>
    <multiplicity>2</multiplicity>
  </arc>
  <arc>
    <id>a13_finalapproval_approved</id>
    <type>regular</type>
    <sourceId>final_approval</sourceId>
    <destinationId>approved</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a14_legalreview_legalreject</id>
    <type>regular</type>
    <sourceId>legal_review</sourceId>
    <destinationId>legal_reject</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a15_legalreject_rejected</id>
    <type>regular</type>
    <sourceId>legal_reject</sourceId>
    <destinationId>rejected</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a16_financereview_financereject</id>
    <type>regular</type>
    <sourceId>finance_review</sourceId>
    <destinationId>finance_reject</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a17_financereject_rejected</id>
    <type>regular</type>
    <sourceId>finance_reject</sourceId>
    <destinationId>rejected</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <!-- CASE EVENTS -->
  <caseEvents>
    <event type="create">
      <id>on_case_create</id>
      <actions phase="pre">
        <action id="9">
<![CDATA[
            status: f.status;
            change status value { "Draft" }
            ]]>
        </action>
      </actions>
    </event>
  </caseEvents>
</document>