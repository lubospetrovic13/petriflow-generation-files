  <transition>
    <id>ai_classify</id>
    <x>304</x>
    <y>208</y>
    <label>AI Classify</label>
    <icon>smart_toy</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>ai_classify_finish</id>
      <actions phase="pre">
        <action id="3">
<![CDATA[
            status: f.status;
            change status value { "Classifying..." }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="4">
<![CDATA[
            sender: f.sender, subject: f.subject, body: f.body, api_key: f.api_key;
            async.run {
            def prompt = """You are an email assistant.
            Classify the following email into one of: general, support, sales, other.
            Extract named entities (people, organizations, products) as a JSON array.
            Suggest a reply draft.
            Return JSON: { "category": "...", "entities": [...], "suggested_reply": "..." }
            
            Sender: ${sender.value}
            Subject: ${subject.value}
            Body: ${body.value}
            """
            def conn = (java.net.HttpURLConnection) new java.net.URL("https://api.openai.com/v1/chat/completions").openConnection()
            conn.setRequestMethod("POST")
            conn.setRequestProperty("Content-Type", "application/json")
            conn.setRequestProperty("Authorization", "Bearer ${api_key.value}")
            conn.setDoOutput(true); conn.setConnectTimeout(15000); conn.setReadTimeout(60000)
            conn.outputStream.write(groovy.json.JsonOutput.toJson([
            model: "gpt-4o-mini",
            messages: [[role: "user", content: prompt]]
            ]).getBytes("UTF-8"))
            def bodyText = ""
            try { bodyText = conn.inputStream.getText("UTF-8") }
            catch (e) { bodyText = conn.errorStream?.getText("UTF-8") ?: '{"error":"unreachable"}' }
            def content = new groovy.json.JsonSlurper().parseText(bodyText)?.choices?.getAt(0)?.message?.content ?: "{}"
            def normalized = content.replaceAll('(?m)^```(?:json)?\\s*','').replaceAll('(?m)^```\\s*$','').trim()
            def parsed = [:]
            try { parsed = new groovy.json.JsonSlurper().parseText(normalized) } catch (e) {}
            def cat = parsed.category ?: "other"
            def ents = (parsed.entities instanceof List) ? groovy.json.JsonOutput.toJson(parsed.entities) : ""
            def reply = parsed.suggested_reply ?: ""
            def t = findTask { it.transitionId.eq("review_ai").and(it.caseId.eq(useCase.stringId)) }
            if (t) setData(t, [
            category: ["value": cat, "type": "enumeration_map"],
            entities: ["value": ents, "type": "text"],
            suggested_reply: ["value": reply, "type": "text"],
            final_reply: ["value": reply, "type": "text"],
            status: ["value": "AI classified", "type": "text"]
            ])
            }
            ]]>
        </action>
      </actions>
    </event>
