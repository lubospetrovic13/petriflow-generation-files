        <action id="9">
<![CDATA[
            request_status: f.request_status;
            
            // Initialize case with start place token
            change request_status value { "New" }
            
            // Set case color
            changeCaseProperty("color").about { "blue" }
            
            // Bootstrap form task so taskRef works immediately
            async.run {
            def formTask = findTask { qTask ->
            qTask.transitionId.eq("t9").and(qTask.caseId.eq(useCase.stringId))
            }
            if (formTask) {
            assignTask(formTask, userService.loggedOrSystem)
            finishTask(formTask)
            }
            }
            ]]>
        </action>
      </actions>
    </event>
