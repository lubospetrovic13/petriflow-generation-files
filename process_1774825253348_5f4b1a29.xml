<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>public_request</id>
  <version>1.0.0</version>
  <initials>PRQ</initials>
  <title>Public Request Submission</title>
  <icon>assignment</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>true</anonymousRole>
  <transitionRole>false</transitionRole>

  <role><id>registration</id><title>Registration Desk</title></role>
  <role><id>legal</id><title>Legal</title></role>
  <role><id>pr</id><title>PR</title></role>
  <role><id>system</id><title>System</title></role>

  <data type="text">
    <id>name</id><title>Name</title><init></init>
  </data>
  <data type="text">
    <id>surname</id><title>Surname</title><init></init>
  </data>
  <data type="text">
    <id>email</id><title>Email</title><init></init>
  </data>
  <data type="text">
    <id>phone</id><title>Phone Number</title><init></init>
  </data>
  <data type="text">
    <id>request_text</id><title>Request Description</title><init></init>
    <component><name>textarea</name></component>
  </data>
  <data type="file">
    <id>attachment</id><title>Attachment</title>
    <component><name>preview</name></component>
  </data>
  <data type="enumeration_map">
    <id>route</id>
    <title>Route To</title>
    <options>
      <option key="legal">Legal</option>
      <option key="pr">PR</option>
    </options>
    <init></init>
  </data>
  <data type="number">
    <id>to_legal</id><title>To Legal</title><init>0</init>
  </data>
  <data type="number">
    <id>to_pr</id><title>To PR</title><init>0</init>
  </data>
  <data type="text">
    <id>legal_statement</id><title>Lawyer Statement</title><init></init>
    <component><name>textarea</name></component>
  </data>
  <data type="text">
    <id>pr_answer</id><title>PR Answer</title><init></init>
    <component><name>textarea</name></component>
  </data>
  <data type="text">
    <id>status</id><title>Status</title><init>Submitted</init>
  </data>

  <data type="taskRef">
    <id>detail_ref</id><title>Status View</title><init>detail_view</init>
  </data>

  <transition>
    <id>submit_request</id><x>208</x><y>208</y><label>Submit Request</label>
    <icon>send</icon><assignPolicy>auto</assignPolicy><priority>1</priority>
    <roleRef><id>anonymous</id><logic><perform>true</perform></logic></roleRef>
    <dataGroup>
      <id>submit_group</id><cols>2</cols><layout>grid</layout><title>Submit Request</title>
      <dataRef>
        <id>name</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>0</x><y>0</y><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>surname</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>1</x><y>0</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>email</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>0</x><y>1</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>phone</id>
        <logic><behavior>editable</behavior><behavior>optional</behavior></logic>
        <layout><x>0</x><y>2</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>0</x><y>3</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>textarea</name></component>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic><behavior>editable</behavior><behavior>optional</behavior></logic>
        <layout><x>0</x><y>4</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>preview</name></component>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>submit_finish</id>
      <actions phase="pre">
        <action id="1"><![CDATA[
          status: f.status;
          change status value { "Submitted" };
        ]]></action>
      </actions>
    </event>
  </transition>

  <transition>
    <id>registration_review</id><x>400</x><y>208</y><label>Registration Review</label>
    <icon>how_to_reg</icon><assignPolicy>auto</assignPolicy><priority>1</priority>
    <roleRef><id>registration</id><logic><perform>true</perform></logic></roleRef>
    <dataGroup>
      <id>reg_group</id><cols>2</cols><layout>grid</layout><title>Review Request</title>
      <dataRef>
        <id>name</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>0</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>surname</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>1</x><y>0</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>email</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>1</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>phone</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>2</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>3</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>textarea</name></component>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>4</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>preview</name></component>
      </dataRef>
      <dataRef>
        <id>route</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>0</x><y>5</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>reg_finish</id>
      <actions phase="pre">
        <action id="2"><![CDATA[
          to_legal: f.to_legal, to_pr: f.to_pr, route: f.route, status: f.status;
          if (route.value == "legal") {
            change to_legal value { 1 }; change to_pr value { 0 };
            change status value { "Sent to Legal" };
          } else {
            change to_legal value { 0 }; change to_pr value { 1 };
            change status value { "Sent to PR" };
          }
        ]]></action>
      </actions>
    </event>
  </transition>

  <transition>
    <id>legal_statement_task</id><x>592</x><y>112</y><label>Legal Statement</label>
    <icon>gavel</icon><assignPolicy>auto</assignPolicy><priority>1</priority>
    <roleRef><id>legal</id><logic><perform>true</perform></logic></roleRef>
    <dataGroup>
      <id>legal_group</id><cols>2</cols><layout>grid</layout><title>Legal Statement</title>
      <dataRef>
        <id>name</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>0</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>surname</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>1</x><y>0</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>1</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>textarea</name></component>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>0</x><y>2</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>textarea</name></component>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>legal_finish</id>
      <actions phase="pre">
        <action id="3"><![CDATA[
          status: f.status;
          change status value { "Legal Statement Provided" };
        ]]></action>
      </actions>
    </event>
  </transition>

  <transition>
    <id>pr_answer_task</id><x>784</x><y>208</y><label>PR Answer</label>
    <icon>record_voice_over</icon><assignPolicy>auto</assignPolicy><priority>1</priority>
    <roleRef><id>pr</id><logic><perform>true</perform></logic></roleRef>
    <dataGroup>
      <id>pr_group</id><cols>2</cols><layout>grid</layout><title>PR Answer</title>
      <dataRef>
        <id>name</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>0</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>surname</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>1</x><y>0</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>email</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>1</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>phone</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>2</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>3</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>textarea</name></component>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>4</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>preview</name></component>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>5</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>textarea</name></component>
      </dataRef>
      <dataRef>
        <id>pr_answer</id>
        <logic><behavior>editable</behavior><behavior>required</behavior></logic>
        <layout><x>0</x><y>6</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>textarea</name></component>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>pr_finish</id>
      <actions phase="pre">
        <action id="4"><![CDATA[
          status: f.status;
          change status value { "Answered" };
        ]]></action>
      </actions>
    </event>
  </transition>

  <transition>
    <id>detail_view</id><x>784</x><y>16</y><label>Status and Answer</label>
    <icon>visibility</icon><assignPolicy>auto</assignPolicy><priority>2</priority>
    <roleRef><id>anonymous</id><logic><perform>true</perform></logic></roleRef>
    <dataGroup>
      <id>detail_group</id><cols>2</cols><layout>grid</layout><title>Status View</title>
      <dataRef>
        <id>status</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>0</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>name</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>1</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>surname</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>1</x><y>1</x><rows>1</rows><cols>1</cols><template>material</template><appearance>outline</appearance></layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>2</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>textarea</name></component>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>3</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>preview</name></component>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>4</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>textarea</name></component>
      </dataRef>
      <dataRef>
        <id>pr_answer</id>
        <logic><behavior>visible</behavior></logic>
        <layout><x>0</x><y>5</x><rows>1</rows><cols>2</cols><template>material</template><appearance>outline</appearance></layout>
        <component><name>textarea</name></component>
      </dataRef>
    </dataGroup>
  </transition>

  <place><id>start</id><x>112</x><y>208</y><label>Start</label><tokens>1</tokens><static>false</static></place>
  <place><id>p_reg</id><x>304</x><y>208</y><label>Registration</label><tokens>0</tokens><static>false</static></place>
  <place><id>p_legal</id><x>496</x><y>112</y><label>Legal</label><tokens>0</tokens><static>false</static></place>
  <place><id>p_pr</id><x>688</x><y>208</y><label>PR</label><tokens>0</tokens><static>false</static></place>
  <place><id>p_detail</id><x>688</x><y>16</y><label>Status View</label><tokens>0</tokens><static>false</static></place>
  <place><id>done</id><x>976</x><y>208</y><label>Done</label><tokens>0</tokens><static>false</static></place>

  <arc><id>a1</id><type>regular</type><sourceId>start</sourceId><destinationId>submit_request</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a2</id><type>regular</type><sourceId>submit_request</sourceId><destinationId>p_reg</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a3</id><type>regular</type><sourceId>p_reg</sourceId><destinationId>registration_review</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a4</id><type>regular</type><sourceId>registration_review</sourceId><destinationId>p_legal</destinationId><multiplicity>0</multiplicity><reference>to_legal</reference></arc>
  <arc><id>a5</id><type>regular</type><sourceId>registration_review</sourceId><destinationId>p_pr</destinationId><multiplicity>0</multiplicity><reference>to_pr</reference></arc>
  <arc><id>a6</id><type>regular</type><sourceId>p_legal</sourceId><destinationId>legal_statement_task</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a7</id><type>regular</type><sourceId>legal_statement_task</sourceId><destinationId>p_pr</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a8</id><type>regular</type><sourceId>p_pr</sourceId><destinationId>pr_answer_task</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a9</id><type>regular</type><sourceId>pr_answer_task</sourceId><destinationId>done</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a10</id><type>regular</type><sourceId>registration_review</sourceId><destinationId>p_detail</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a11</id><type>regular</type><sourceId>legal_statement_task</sourceId><destinationId>p_detail</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a12</id><type>regular</type><sourceId>pr_answer_task</sourceId><destinationId>p_detail</destinationId><multiplicity>1</multiplicity></arc>
  <arc><id>a13</id><type>read</type><sourceId>p_detail</sourceId><destinationId>detail_view</destinationId><multiplicity>1</multiplicity></arc>
</document>
