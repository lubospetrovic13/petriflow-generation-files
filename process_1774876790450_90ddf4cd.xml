    <event type="finish">
      <id>triage_finish</id>
      <actions phase="pre">
        <action id="4">
<![CDATA[
            to_legal: f.to_legal, to_pr: f.to_pr, route_decision: f.route_decision, status: f.status;
            if (route_decision.value == "legal") {
            change to_legal value { 1 }; change to_pr value { 0 };
            change status value { "In Legal Review" }
            } else {
            change to_legal value { 0 }; change to_pr value { 1 };
            change status value { "In PR Review" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="5">
<![CDATA[
            async.run {
            if (f.route_decision.value == "legal") { assignTask("t_legal"); finishTask("t_legal") }
            else { assignTask("t_pr"); finishTask("t_pr") }
            }
            ]]>
        </action>
      </actions>
    </event>
