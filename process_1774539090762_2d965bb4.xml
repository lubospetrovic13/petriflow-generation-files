    <event type="finish">
      <id>on_backup_finish</id>
      <actions phase="pre">
        <action id="1">
<![CDATA[
            to_hr: f.to_hr, to_employee_manager: f.to_employee_manager, to_done_manager: f.to_done_manager, manager_decision: f.manager_decision, status: f.status, approved_by_manager: f.approved_by_manager;
            if (manager_decision.value == "approve") {
            change to_hr value { 1 }
            change to_employee_manager value { 0 }
            change to_done_manager value { 0 }
            change status value { "Pending HR Approval" }
            change approved_by_manager value { userService.loggedOrSystem.email }
            } else if (manager_decision.value == "reject") {
            change to_hr value { 0 }
            change to_employee_manager value { 1 }
            change to_done_manager value { 0 }
            change status value { "Rejected by Manager - Revision Required" }
            } else {
            change to_hr value { 0 }
            change to_employee_manager value { 0 }
            change to_done_manager value { 1 }
            change status value { "Delegation Not Allowed from Backup" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="2">
<![CDATA[
            submitted_by: f.submitted_by, manager_decision: f.manager_decision, manager_comments: f.manager_comments;
            if (manager_decision.value == "approve") {
            sendEmail([submitted_by.value], "Leave Request - Pending HR Approval", "Your leave request has been approved by the backup manager and is now pending HR approval.\n\nComments: ${manager_comments.value}")
            } else if (manager_decision.value == "reject") {
            sendEmail([submitted_by.value], "Leave Request - Rejected", "Your leave request has been rejected by the backup manager. Please revise and resubmit.\n\nComments: ${manager_comments.value}")
            }
            ]]>
        </action>
      </actions>
    </event>
