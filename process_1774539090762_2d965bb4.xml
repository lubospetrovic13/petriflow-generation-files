            make delegate_to, hidden on t_manager_review when { true }
            ]]>
        </action>
      </actions>
    </event>
    <event type="finish">
      <id>on_manager_finish</id>
      <actions phase="pre">
        <action id="6">
<![CDATA[
            to_hr: f.to_hr, to_employee_manager: f.to_employee_manager, to_backup: f.to_backup, manager_decision: f.manager_decision, status: f.status, approved_by_manager: f.approved_by_manager, delegate_to: f.delegate_to;
            if (manager_decision.value == "approve") {
            change to_hr value { 1 }
            change to_employee_manager value { 0 }
            change to_backup value { 0 }
            change status value { "Pending HR Approval" }
            change approved_by_manager value { userService.loggedOrSystem.email }
            } else if (manager_decision.value == "reject") {
            change to_hr value { 0 }
            change to_employee_manager value { 1 }
            change to_backup value { 0 }
            change status value { "Rejected by Manager - Revision Required" }
            } else {
            if (!delegate_to.value) {
            throw new java.lang.IllegalStateException("Please select a backup approver.")
            }
            change to_hr value { 0 }
            change to_employee_manager value { 0 }
            change to_backup value { 1 }
            change status value { "Delegated to Backup Approver" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="7">
<![CDATA[
            submitted_by: f.submitted_by, manager_decision: f.manager_decision, manager_comments: f.manager_comments, delegate_to: f.delegate_to;
            if (manager_decision.value == "approve") {
            sendEmail([submitted_by.value], "Leave Request - Pending HR Approval", "Your leave request has been approved by your manager and is now pending HR approval.\n\nComments: ${manager_comments.value}")
            } else if (manager_decision.value == "reject") {
            sendEmail([submitted_by.value], "Leave Request - Rejected", "Your leave request has been rejected by your manager. Please revise and resubmit.\n\nComments: ${manager_comments.value}")
            } else {
            def backupEmail = (delegate_to.value as List)?.first()?.email ?: ""
            if (backupEmail) {
            sendEmail([backupEmail], "Leave Request - Delegated to You", "A leave request has been delegated to you for approval.\n\nCase: ${useCase.title}")
            }
            }
            ]]>
        </action>
      </actions>
    </event>
    <event type="set">
