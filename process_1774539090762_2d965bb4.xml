      <actions phase="post">
        <action id="8">
<![CDATA[
            t_manager_review: t.manager_review, manager_decision: f.manager_decision, delegate_to: f.delegate_to;
            if (manager_decision.value == "delegate") {
            make delegate_to, required on t_manager_review when { true }
            } else {
            make delegate_to, hidden on t_manager_review when { true }
            }
            ]]>
        </action>
      </actions>
