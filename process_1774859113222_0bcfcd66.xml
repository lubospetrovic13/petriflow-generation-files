<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>public_request</id>
  <version>1.0.0</version>
  <initials>PRQ</initials>
  <title>Public Request Form</title>
  <icon>assignment</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>true</anonymousRole>
  <transitionRole>false</transitionRole>
  <caseEvents>
    <event type="create">
      <id>on_create</id>
      <actions phase="post">
        <action id="1">
<![CDATA[
            status: f.status;
            change status value { "Submitted — awaiting review" }
            ]]>
        </action>
      </actions>
    </event>
  </caseEvents>
  <role>
    <id>registration</id>
    <title>Registration Desk</title>
  </role>
  <role>
    <id>legal</id>
    <title>Legal</title>
  </role>
  <role>
    <id>pr</id>
    <title>PR</title>
  </role>
  <role>
    <id>system</id>
    <title>System</title>
  </role>
  <data type="text">
    <id>first_name</id>
    <title>First Name</title>
  </data>
  <data type="text">
    <id>last_name</id>
    <title>Last Name</title>
  </data>
  <data type="text">
    <id>email</id>
    <title>Email</title>
  </data>
  <data type="text">
    <id>phone</id>
    <title>Phone Number</title>
  </data>
  <data type="text">
    <id>request_text</id>
    <title>Request Description</title>
  </data>
  <data type="file">
    <id>attachment</id>
    <title>Attachment</title>
  </data>
  <data type="text">
    <id>status</id>
    <title>Current Status</title>
  </data>
  <data type="enumeration_map">
    <id>routing_decision</id>
    <title>Route To</title>
    <options>
      <option key="legal">Legal then PR</option>
      <option key="pr">PR directly</option>
    </options>
  </data>
  <data type="number">
    <id>go_legal</id>
    <title>Go Legal</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_pr_direct</id>
    <title>Go PR Direct</title>
    <init>0</init>
  </data>
  <data type="text">
    <id>legal_statement</id>
    <title>Legal Statement</title>
  </data>
  <data type="text">
    <id>pr_answer</id>
    <title>Answer to Submitter</title>
  </data>
  <!-- TRANSITIONS -->
  <transition>
    <id>t_submit</id>
    <x>208</x>
    <y>208</y>
    <label>Submit Request</label>
    <icon>send</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>anonymous</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_submit</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Your Request</title>
      <dataRef>
        <id>first_name</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>last_name</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>email</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>phone</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>optional</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>optional</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <transition>
    <id>t_registration</id>
    <x>496</x>
    <y>208</y>
    <label>Review and Route</label>
    <icon>manage_accounts</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>registration</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_registration</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Incoming Request</title>
      <dataRef>
        <id>first_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>last_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>email</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>phone</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>routing_decision</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>reg_finish</id>
      <actions phase="pre">
        <action id="2">
<![CDATA[
            go_legal: f.go_legal, go_pr_direct: f.go_pr_direct,
            routing_decision: f.routing_decision, status: f.status;
            if (routing_decision.value == "legal") {
            change go_legal value { 1 }
            change go_pr_direct value { 0 }
            change status value { "Under legal review" }
            } else {
            change go_legal value { 0 }
            change go_pr_direct value { 1 }
            change status value { "Under PR review" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="3">
<![CDATA[
            async.run { assignTask("t_router"); finishTask("t_router") }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- System router: consumes token from p_routing, distributes via variable arcs -->
  <transition>
    <id>t_router</id>
    <x>688</x>
    <y>208</y>
    <label>Router</label>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
  </transition>
  <transition>
    <id>t_legal</id>
    <x>880</x>
    <y>80</y>
    <label>Write Legal Statement</label>
    <icon>gavel</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>legal</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_legal</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Legal Review</title>
      <dataRef>
        <id>first_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>last_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>legal_finish</id>
      <actions phase="pre">
        <action id="4">
<![CDATA[
            status: f.status;
            change status value { "Legal review complete — awaiting PR" }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>t_pr</id>
    <x>1072</x>
    <y>208</y>
    <label>Write PR Answer</label>
    <icon>forum</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>pr</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_pr</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>PR Response</title>
      <dataRef>
        <id>first_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>last_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>email</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>pr_answer</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>5</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>pr_finish</id>
      <actions phase="pre">
        <action id="5">
<![CDATA[
            status: f.status;
            change status value { "Answered" }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="6">
<![CDATA[
            email: f.email, first_name: f.first_name, pr_answer: f.pr_answer;
            sendEmail(
            [email.value],
            "Your request has been answered",
            "Dear ${first_name.value},\n\n${pr_answer.value}\n\nThank you for contacting us."
            )
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- Persistent status view — read arc only, never finishes -->
  <transition>
    <id>t_status_view</id>
    <x>496</x>
    <y>16</y>
    <label>Request Status</label>
    <icon>info</icon>
    <priority>2</priority>
    <roleRef>
      <id>anonymous</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_status</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Your Request Status</title>
      <dataRef>
        <id>first_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>last_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>request_text</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>pr_answer</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
    </dataGroup>
  </transition>
  <!-- PLACES -->
  <place>
    <id>p_start</id>
    <x>112</x>
    <y>208</y>
    <label>Start</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <!-- Token deposited by submit; read arc keeps status view alive forever -->
  <place>
    <id>p_status</id>
    <x>352</x>
    <y>16</y>
    <label>Status Active</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_submitted</id>
    <x>352</x>
    <y>208</y>
    <label>Submitted</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_routing</id>
    <x>592</x>
    <y>208</y>
    <label>Routing</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_legal_queue</id>
    <x>784</x>
    <y>80</y>
    <label>Legal Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_pr_queue</id>
    <x>784</x>
    <y>336</y>
    <label>PR Direct Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <!-- Legal path deposits token here; t_pr consumes from here OR from p_pr_queue -->
  <place>
    <id>p_pr_after_legal</id>
    <x>976</x>
    <y>80</y>
    <label>PR After Legal</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_done</id>
    <x>1264</x>
    <y>208</y>
    <label>Done</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <!-- ARCS -->
  <!-- p_start → t_submit → p_submitted + p_status -->
  <arc>
    <id>a1</id>
    <type>regular</type>
    <sourceId>p_start</sourceId>
    <destinationId>t_submit</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2</id>
    <type>regular</type>
    <sourceId>t_submit</sourceId>
    <destinationId>p_submitted</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3</id>
    <type>regular</type>
    <sourceId>t_submit</sourceId>
    <destinationId>p_status</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <!-- p_status read arc → status view (token never consumed) -->
  <arc>
    <id>a4</id>
    <type>read</type>
    <sourceId>p_status</sourceId>
    <destinationId>t_status_view</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <!-- p_submitted → t_registration → p_routing -->
  <arc>
    <id>a5</id>
    <type>regular</type>
    <sourceId>p_submitted</sourceId>
    <destinationId>t_registration</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a6</id>
    <type>regular</type>
    <sourceId>t_registration</sourceId>
    <destinationId>p_routing</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <!-- p_routing → t_router (system) -->
  <arc>
    <id>a7</id>
    <type>regular</type>
    <sourceId>p_routing</sourceId>
    <destinationId>t_router</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <!-- t_router variable arc → p_legal_queue (ref: go_legal) -->
  <arc>
    <id>a8</id>
    <type>regular</type>
    <sourceId>t_router</sourceId>
    <destinationId>p_legal_queue</destinationId>
    <multiplicity>0</multiplicity>
    <reference>go_legal</reference>
  </arc>
  <!-- t_router variable arc → p_pr_queue (ref: go_pr_direct) -->
  <arc>
    <id>a9</id>
    <type>regular</type>
    <sourceId>t_router</sourceId>
    <destinationId>p_pr_queue</destinationId>
    <multiplicity>0</multiplicity>
    <reference>go_pr_direct</reference>
  </arc>
  <!-- Legal path: p_legal_queue → t_legal → p_pr_after_legal -->
  <arc>
    <id>a10</id>
    <type>regular</type>
    <sourceId>p_legal_queue</sourceId>
    <destinationId>t_legal</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
