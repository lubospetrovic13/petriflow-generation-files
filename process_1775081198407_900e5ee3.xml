<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>leave_request</id>
  <version>1.0.0</version>
  <initials>LR</initials>
  <title>Leave Request Process</title>
  <icon>event</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <role>
    <id>manager</id>
    <title>Manager</title>
  </role>
  <data type="text">
    <id>reason</id>
    <title>Reason for Leave</title>
  </data>
  <transition>
    <id>submit</id>
    <x>304</x>
    <y>208</y>
    <label>Submit Request</label>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>default</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_0</id>
      <cols>1</cols>
      <layout>grid</layout>
      <title>Request Details</title>
      <dataRef>
        <id>reason</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <transition>
    <id>review</id>
    <x>688</x>
    <y>208</y>
    <label>Review Request</label>
    <roleRef>
      <id>manager</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_1</id>
      <cols>1</cols>
      <layout>grid</layout>
      <title>Review</title>
      <dataRef>
        <id>reason</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <place>
    <id>start</id>
    <x>112</x>
    <y>208</y>
    <label>Start</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_pending</id>
    <x>496</x>
    <y>208</y>
    <label>Pending Approval</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>done</id>
    <x>880</x>
    <y>208</y>
    <label>Processed</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <arc>
    <id>a1</id>
    <type>regular</type>
    <sourceId>start</sourceId>
    <destinationId>submit</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2</id>
    <type>regular</type>
    <sourceId>submit</sourceId>
    <destinationId>p_pending</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3</id>
    <type>regular</type>
    <sourceId>p_pending</sourceId>
    <destinationId>review</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a4</id>
    <type>regular</type>
    <sourceId>review</sourceId>
    <destinationId>done</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
</document>