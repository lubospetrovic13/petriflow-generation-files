<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>invoice_process</id>
  <version>1.0.0</version>
  <initials>INV</initials>
  <title>Invoice Process</title>
  <icon>receipt</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <role>
    <id>system</id>
    <title>System</title>
  </role>
  <data type="text">
    <id>invoice_number</id>
    <title>Invoice Number</title>
  </data>
  <data type="number">
    <id>amount</id>
    <title>Amount</title>
    <component>
      <name>currency</name>
    </component>
  </data>
  <data type="date">
    <id>invoice_date</id>
    <title>Invoice Date</title>
  </data>
  <data type="file">
    <id>invoice_file</id>
    <title>Invoice File</title>
  </data>
  <data type="enumeration_map">
    <id>order_case_id</id>
    <title>Link to Order</title>
  </data>
  <data type="enumeration_map">
    <id>invoice_decision</id>
    <title>Invoice Approval</title>
    <options>
      <option key="approve">Approve</option>
      <option key="reject">Reject</option>
    </options>
  </data>
  <transition>
    <id>register_invoice</id>
    <x>112</x>
    <y>208</y>
    <label>Register Invoice</label>
    <icon>add_box</icon>
    <assignPolicy>auto</assignPolicy>
    <event type="assign">
      <id>ri_ass</id>
      <actions phase="pre">
        <action id="1">
<![CDATA[
            order_case_id: f.order_case_id;
            def orders = findCases { it.processIdentifier.eq("order_process") }
            .findAll { c -> c.dataSet?.get("status")?.value == "Approved" }
            .collectEntries { [(it.stringId): it.title ?: it.stringId] }
            change order_case_id options { orders }
            ]]>
        </action>
      </actions>
    </event>
    <dataGroup>
      <id>dg_reg</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Invoice Information</title>
      <dataRef>
        <id>order_case_id</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>invoice_number</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>amount</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>invoice_date</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>invoice_file</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>2</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>ri_fin</id>
      <actions phase="post">
        <action id="2">
<![CDATA[
            order_case_id: f.order_case_id;
            def parent = findCase { it._id.eq(order_case_id.value) }
            if (parent) {
            setData("invoice_listener", parent, ["refresh_trigger": ["value": java.util.UUID.randomUUID().toString(), "type": "text"]])
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>invoice_detail</id>
    <x>496</x>
    <y>16</y>
    <label>Invoice Review</label>
    <icon>assignment_turned_in</icon>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_inv_det</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Invoice Review</title>
      <dataRef>
        <id>invoice_number</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>amount</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>invoice_file</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>invoice_decision</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <place>
    <id>p_start</id>
    <x>112</x>
    <y>304</y>
    <label>Start</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_pending</id>
    <x>304</x>
    <y>208</y>
    <label>Pending Approval</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <arc>
    <id>a1</id>
    <type>regular</type>
    <sourceId>p_start</sourceId>
    <destinationId>register_invoice</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2</id>
    <type>regular</type>
    <sourceId>register_invoice</sourceId>
    <destinationId>p_pending</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3</id>
    <type>read</type>
    <sourceId>p_pending</sourceId>
    <destinationId>invoice_detail</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
</document>