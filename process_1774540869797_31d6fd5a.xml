            manager_decision: f.manager_decision,
            manager_comment: f.manager_comment,
            revision_count: f.revision_count,
            manager_reject: f.manager_reject;
            if (manager_decision.value == "reject" && manager_reject.value == 1) {
            def current = (revision_count.value as Integer) ?: 0
            change revision_count value { (current + 1) as Double }
            sendEmail(
            [employee_email.value],
            "Leave Request Rejected - ${useCase.title}",
            "Your leave request has been rejected by your manager. Please review the comments and resubmit.\n\nManager Comment: ${manager_comment.value}"
