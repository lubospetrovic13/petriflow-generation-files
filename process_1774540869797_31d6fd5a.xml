            change status value { "Pending Manager Review" }
            change employee_email value { userService.loggedOrSystem.email }
            if (start_date.value != null && end_date.value != null) {
            def daysDiff = java.time.temporal.ChronoUnit.DAYS.between(
            start_date.value as java.time.LocalDate,
            end_date.value as java.time.LocalDate
            )
            change days_count value { (daysDiff + 1) as java.lang.Double }
            }
