      <id>on_manager_finish</id>
      <actions phase="pre">
        <action id="3">
<![CDATA[
            to_hr_review: f.to_hr_review,
            to_resubmit: f.to_resubmit,
            manager_decision: f.manager_decision,
            status: f.status,
            manager_reject: f.manager_reject;
            if (manager_decision.value == "approve") {
            change to_hr_review value { 1 }
            change to_resubmit value { 0 }
            change manager_reject value { 0 }
            change status value { "Pending HR Review" }
            } else {
            change to_hr_review value { 0 }
            change to_resubmit value { 1 }
            change manager_reject value { 1 }
            change status value { "Rejected by Manager" }
            }
            ]]>
