    </dataGroup>
    <event type="finish">
      <id>on_hr_finish</id>
      <actions phase="pre">
        <action id="1">
<![CDATA[
            to_approved: f.to_approved,
            to_resubmit: f.to_resubmit,
            manager_decision: f.manager_decision,
            status: f.status,
            hr_reject: f.hr_reject;
            if (manager_decision.value == "approve") {
            change to_approved value { 1 }
            change to_resubmit value { 0 }
            change hr_reject value { 0 }
            change status value { "HR Approved" }
            } else {
            change to_approved value { 0 }
            change to_resubmit value { 1 }
            change hr_reject value { 1 }
            change status value { "Rejected by HR" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="2">
<![CDATA[
            employee_email: f.employee_email,
            manager_decision: f.manager_decision,
            start_date: f.start_date,
            end_date: f.end_date,
            hr_comment: f.hr_comment,
            revision_count: f.revision_count,
            hr_reject: f.hr_reject;
            if (manager_decision.value == "approve") {
            def startStr = start_date.value?.format(java.time.format.DateTimeFormatter.ofPattern('dd/MM/yyyy')) ?: ""
            def endStr = end_date.value?.format(java.time.format.DateTimeFormatter.ofPattern('dd/MM/yyyy')) ?: ""
            sendEmail(
            [employee_email.value],
            "Leave Request Approved - ${useCase.title}",
            "Your leave request has been approved by HR.\n\nDates: ${startStr} - ${endStr}\n\nHR Comment: ${hr_comment.value}"
            )
            } else {
            if (hr_reject.value == 1) {
            def current = (revision_count.value as Integer) ?: 0
            change revision_count value { (current + 1) as Double }
            sendEmail(
            [employee_email.value],
            "Leave Request Rejected by HR - ${useCase.title}",
            "Your leave request has been rejected by HR. Please review the comments and resubmit.\n\nHR Comment: ${hr_comment.value}"
            )
            }
            }
            ]]>
        </action>
      </actions>
    </event>
