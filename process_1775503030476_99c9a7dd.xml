          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>finance_comment</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>finance_review_finish</id>
      <actions phase="pre">
        <action id="6">
<![CDATA[
            finance_decision: f.finance_decision, finance_approve: f.finance_approve, finance_reject: f.finance_reject, from_finance: f.from_finance, status: f.status;
            if (finance_decision.value == "approve") {
            change finance_approve value { 1 }; change finance_reject value { 0 }; change from_finance value { 1 }
            } else {
            change finance_approve value { 0 }; change finance_reject value { 1 }; change from_finance value { 0 }
            change status value { "Rejected by Finance" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="7">
<![CDATA[
            async.run {
            def t = findTask { it.transitionId.eq("join").and(it.caseId.eq(useCase.stringId)) }
            if (t) { assignTask(t, userService.loggedOrSystem); finishTask(t, userService.loggedOrSystem) }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- AND-join system evaluation -->
  <transition>
    <id>join</id>
    <x>784</x>
    <y>208</y>
    <label>Evaluate Reviews</label>
    <icon>rule</icon>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>join_finish</id>
      <actions phase="pre">
        <action id="8">
<![CDATA[
            legal_decision: f.legal_decision, finance_decision: f.finance_decision, go_loop: f.go_loop, go_manager: f.go_manager, status: f.status;
            if (legal_decision.value == "approve" && finance_decision.value == "approve") {
            change go_manager value { 1 }; change go_loop value { 0 }
            change status value { "Pending Manager Decision" }
            } else {
            change go_manager value { 0 }; change go_loop value { 1 }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="9">
<![CDATA[
            // If rejected, notify submitter by email with reasons
            legal_decision: f.legal_decision, finance_decision: f.finance_decision, legal_comment: f.legal_comment, finance_comment: f.finance_comment, submitter_email: f.submitter_email, go_loop: f.go_loop;
            if (go_loop.value == 1 && submitter_email.value) {
            def reasons = []
            if (legal_decision.value == "reject") reasons << "Legal: " + (legal_comment.value ?: "")
            if (finance_decision.value == "reject") reasons << "Finance: " + (finance_comment.value ?: "")
            sendEmail([submitter_email.value], "PO Rejected", "Your purchase order was rejected:\n" + reasons.join("\n"))
            }
            // If approved, bootstrap manager task
            if (go_manager.value == 1) {
            async.run { assignTask("manager_decision"); finishTask("manager_decision") }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
