    <options>
      <option key="approve">Approve</option>
      <option key="reject">Reject</option>
    </options>
  </data>
  <data type="enumeration_map">
    <id>final_decision</id>
    <title>Final Decision</title>
    <options>
      <option key="issue">Issue PO</option>
      <option key="reject">Reject</option>
    </options>
  </data>
  <data type="text">
    <id>final_comment</id>
    <title>Manager Comment</title>
    <init/>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="text">
    <id>status</id>
    <title>Status</title>
    <init/>
  </data>
  <data type="text">
    <id>submitter_email</id>
    <title>Submitter Email</title>
    <init/>
  </data>
  <data type="taskRef">
    <id>status_view</id>
    <title>Status View</title>
    <init>status_task</init>
  </data>
  <!-- Routing fields for AND-join and loop -->
  <data type="number">
    <id>legal_approve</id>
    <title>Legal Approve</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>legal_reject</id>
    <title>Legal Reject</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>finance_approve</id>
    <title>Finance Approve</title>
