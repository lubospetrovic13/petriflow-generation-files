    <id>split</id>
    <x>400</x>
    <y>208</y>
    <label>Parallel Review Split</label>
    <icon>call_split</icon>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
