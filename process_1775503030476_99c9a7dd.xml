          <name>textarea</name>
        </component>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>manager_decision_finish</id>
      <actions phase="pre">
        <action id="12">
<![CDATA[
            final_decision: f.final_decision, go_issued: f.go_issued, go_final_reject: f.go_final_reject, status: f.status;
            if (final_decision.value == "issue") {
            change go_issued value { 1 }; change go_final_reject value { 0 }
            change status value { "PO Issued" }
            } else {
            change go_issued value { 0 }; change go_final_reject value { 1 }
            change status value { "Rejected by Manager" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="13">
<![CDATA[
            // Notify submitter if issued
            final_decision: f.final_decision, submitter_email: f.submitter_email;
            if (final_decision.value == "issue" && submitter_email.value) {
            sendEmail([submitter_email.value], "PO Issued", "Your purchase order has been issued.")
            }
            ]]>
        </action>
      </actions>
