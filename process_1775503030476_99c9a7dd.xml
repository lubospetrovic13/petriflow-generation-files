    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>legal</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>legal_group</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Legal Review</title>
      <dataRef>
        <id>legal_decision</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_comment</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>legal_review_finish</id>
      <actions phase="pre">
        <action id="4">
<![CDATA[
            legal_decision: f.legal_decision, legal_approve: f.legal_approve, legal_reject: f.legal_reject, from_legal: f.from_legal, status: f.status;
            if (legal_decision.value == "approve") {
            change legal_approve value { 1 }; change legal_reject value { 0 }; change from_legal value { 1 }
            } else {
            change legal_approve value { 0 }; change legal_reject value { 1 }; change from_legal value { 0 }
            change status value { "Rejected by Legal" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="5">
<![CDATA[
            async.run {
            def t = findTask { it.transitionId.eq("join").and(it.caseId.eq(useCase.stringId)) }
            if (t) { assignTask(t, userService.loggedOrSystem); finishTask(t, userService.loggedOrSystem) }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- Finance Review -->
