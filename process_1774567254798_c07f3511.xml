  <transition>
    <id>t_handle_rejection</id>
    <x>784</x>
    <y>208</y>
    <label>Handle Rejection</label>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>rejection_finish</id>
      <actions phase="post">
        <action id="8">
<![CDATA[
            submitter_email: f.submitter_email,
            legal_decision: f.legal_decision,
            legal_comment: f.legal_comment,
            finance_decision: f.finance_decision,
            finance_comment: f.finance_comment,
            vendor_name: f.vendor_name,
            status: f.status;
            def rejector = ""
            def reason = ""
            if (legal_decision.value == "reject") {
            rejector = "Legal"
            reason = legal_comment.value ?: "(no comment provided)"
            } else if (finance_decision.value == "reject") {
            rejector = "Finance"
            reason = finance_comment.value ?: "(no comment provided)"
            }
            changeCaseProperty("color").about { "orange" }
            if (submitter_email.value) {
            sendEmail(
            [submitter_email.value],
            "Purchase Order Rejected — Action Required",
            "Your purchase order for vendor '${vendor_name.value}' has been rejected by the ${rejector} department.\n\nReason: ${reason}\n\nPlease log in, review the feedback, revise your submission and resubmit."
            )
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>t_and_join</id>
    <x>880</x>
    <y>208</y>
    <label>Both Reviews Done</label>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>and_join_finish</id>
      <actions phase="post">
        <action id="9">
<![CDATA[
            status: f.status;
            change status value { "Awaiting Procurement Manager Decision" }
            async.run {
            def t = findTask { it.transitionId.eq("t_manager_review").and(it.caseId.eq(useCase.stringId)) }
            if (t) { assignTask(t, userService.loggedOrSystem); finishTask(t, userService.loggedOrSystem) }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>t_manager_review</id>
    <x>1072</x>
    <y>208</y>
    <label>Final Approval</label>
    <icon>verified</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>procurement_manager</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>manager_finish</id>
      <actions phase="pre">
        <action id="10">
<![CDATA[
            go_manager_issue: f.go_manager_issue,
            go_manager_reject: f.go_manager_reject,
            manager_decision: f.manager_decision,
            status: f.status;
            if (manager_decision.value == "issue") {
            change go_manager_issue value { 1 }
            change go_manager_reject value { 0 }
            change status value { "PO Issued" }
            } else {
            change go_manager_issue value { 0 }
            change go_manager_reject value { 1 }
            change status value { "Rejected by Procurement Manager" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="11">
<![CDATA[
            manager_decision: f.manager_decision;
            if (manager_decision.value == "issue") {
            async.run { assignTask("t_notify_issued"); finishTask("t_notify_issued") }
            } else {
            async.run { assignTask("t_notify_mgr_reject"); finishTask("t_notify_mgr_reject") }
            }
            ]]>
        </action>
      </actions>
    </event>
