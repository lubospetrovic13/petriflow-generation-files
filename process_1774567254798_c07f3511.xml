    <event type="finish">
      <id>notify_issued_finish</id>
      <actions phase="post">
        <action id="12">
<![CDATA[
            submitter_email: f.submitter_email,
            vendor_name: f.vendor_name,
            amount: f.amount,
            manager_comment: f.manager_comment;
            def commentLine = manager_comment.value ? "\n\nProcurement Manager Note: ${manager_comment.value}" : ""
            if (submitter_email.value) {
            sendEmail(
            [submitter_email.value],
            "Purchase Order Issued — ${vendor_name.value}",
            "Your purchase order for vendor '${vendor_name.value}' (Amount: ${amount.value}) has been fully approved and issued.${commentLine}\n\nThank you."
            )
            }
            changeCaseProperty("color").about { "green" }
