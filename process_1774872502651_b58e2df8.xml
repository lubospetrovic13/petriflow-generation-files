<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>procurement_workflow</id>
  <version>1.0.0</version>
  <initials>PO</initials>
  <title>Purchase Order Workflow</title>
  <icon>shopping_cart</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <caseEvents>
    <event type="create">
      <id>on_create</id>
      <actions phase="post">
        <action id="1">
<![CDATA[
            status: f.status;
            change status value { "Draft" }
            ]]>
        </action>
      </actions>
    </event>
  </caseEvents>
  <role>
    <id>submitter</id>
    <title>Submitter</title>
  </role>
  <role>
    <id>legal</id>
    <title>Legal Reviewer</title>
  </role>
  <role>
    <id>finance</id>
    <title>Finance Reviewer</title>
  </role>
  <role>
    <id>procurement_manager</id>
    <title>Procurement Manager</title>
  </role>
  <role>
    <id>system</id>
    <title>System</title>
  </role>
  <!-- ═══════════════════════════ DATA FIELDS ═══════════════════════════ -->
  <data type="text">
    <id>vendor_name</id>
    <title>Vendor Name</title>
  </data>
  <data type="number">
    <id>amount</id>
    <title>Amount</title>
  </data>
  <data type="enumeration_map">
    <id>category</id>
    <title>Category</title>
    <options>
      <option key="software">Software</option>
      <option key="hardware">Hardware</option>
      <option key="services">Services</option>
      <option key="other">Other</option>
    </options>
  </data>
  <data type="text">
    <id>business_justification</id>
    <title>Business Justification</title>
  </data>
  <data type="text">
    <id>description</id>
    <title>Detailed Description</title>
  </data>
  <data type="file">
    <id>supporting_doc</id>
    <title>Supporting Document</title>
  </data>
  <data type="text">
    <id>status</id>
    <title>Current Status</title>
    <desc>Tracks the current state of this purchase order request.</desc>
  </data>
  <data type="text">
    <id>submitter_email</id>
    <title>Submitter Email</title>
  </data>
  <!-- Legal review fields -->
  <data type="enumeration_map">
    <id>legal_decision</id>
    <title>Legal Decision</title>
    <options>
      <option key="approve">Approve</option>
      <option key="reject">Reject</option>
    </options>
  </data>
  <data type="text">
    <id>legal_comment</id>
    <title>Legal Review Comment</title>
  </data>
  <!-- Finance review fields -->
  <data type="enumeration_map">
    <id>finance_decision</id>
    <title>Finance Decision</title>
    <options>
      <option key="approve">Approve</option>
      <option key="reject">Reject</option>
    </options>
  </data>
  <data type="text">
    <id>finance_comment</id>
    <title>Finance Review Comment</title>
  </data>
  <!-- Final decision fields -->
  <data type="enumeration_map">
    <id>final_decision</id>
    <title>Final Decision</title>
    <options>
      <option key="issue">Issue PO</option>
      <option key="reject">Reject PO</option>
    </options>
  </data>
  <data type="text">
    <id>final_comment</id>
    <title>Final Decision Comment</title>
  </data>
  <!-- Routing number fields -->
  <data type="number">
    <id>go_legal_approve</id>
    <title>Legal Approve</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_legal_reject</id>
    <title>Legal Reject</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_finance_approve</id>
    <title>Finance Approve</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_finance_reject</id>
    <title>Finance Reject</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_final_issue</id>
    <title>Final Issue</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_final_reject</id>
    <title>Final Reject</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_loop_legal</id>
    <title>Loop from Legal</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_loop_finance</id>
    <title>Loop from Finance</title>
    <init>0</init>
  </data>
  <!-- ═══════════════════════════ TRANSITIONS ═══════════════════════════ -->
  <!-- Submit Purchase Order -->
  <transition>
    <id>t_submit</id>
    <x>208</x>
    <y>208</y>
    <label>Submit Purchase Order</label>
    <icon>send</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>submitter</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_submit</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Purchase Order Details</title>
      <dataRef>
        <id>vendor_name</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>amount</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>category</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>submitter_email</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>business_justification</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>optional</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>supporting_doc</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>optional</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>t_submit_finish</id>
      <actions phase="pre">
        <action id="2">
<![CDATA[
            status: f.status, submitter_email: f.submitter_email;
            change status value { "Under Review" }
            if (!submitter_email.value) {
            change submitter_email value { userService.loggedOrSystem.email }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="3">
<![CDATA[
            async.run { assignTask("t_split"); finishTask("t_split") }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- AND-split system task -->
  <transition>
    <id>t_split</id>
    <x>400</x>
    <y>208</y>
    <label>Split to Parallel Review</label>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
  </transition>
  <!-- Legal Review -->
  <transition>
    <id>t_legal_review</id>
    <x>592</x>
    <y>80</y>
    <label>Legal Review</label>
    <icon>gavel</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>legal</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_legal</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Legal Compliance Review</title>
      <dataRef>
        <id>vendor_name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>amount</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>category</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>business_justification</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>supporting_doc</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_decision</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>5</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <event type="set">
          <id>legal_decision_set</id>
          <actions phase="post">
            <action id="4">
<![CDATA[
                legal_decision: f.legal_decision, legal_comment: f.legal_comment, t_legal_review: t.t_legal_review;
                if (legal_decision.value == "reject") {
                make legal_comment, required on t_legal_review when { true }
                } else {
                make legal_comment, optional on t_legal_review when { true }
                }
                ]]>
            </action>
          </actions>
        </event>
      </dataRef>
      <dataRef>
        <id>legal_comment</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>optional</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>5</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>t_legal_finish</id>
      <actions phase="pre">
        <action id="5">
<![CDATA[
            go_legal_approve: f.go_legal_approve, go_legal_reject: f.go_legal_reject,
            go_loop_legal: f.go_loop_legal, legal_decision: f.legal_decision;
            if (legal_decision.value == "approve") {
            change go_legal_approve value { 1 }
            change go_legal_reject  value { 0 }
            change go_loop_legal    value { 0 }
            } else {
            change go_legal_approve value { 0 }
            change go_legal_reject  value { 1 }
            change go_loop_legal    value { 1 }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="6">
<![CDATA[
            legal_decision: f.legal_decision, status: f.status,
            submitter_email: f.submitter_email, legal_comment: f.legal_comment;
            if (legal_decision.value == "reject") {
            change status value { "Rejected by Legal" }
            sendEmail(
            [submitter_email.value],
            "Purchase Order Rejected by Legal",
            "Your purchase order has been rejected by the Legal department.\n\nComment: ${legal_comment.value ?: 'No comment provided.'}\n\nPlease revise and resubmit."
            )
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
