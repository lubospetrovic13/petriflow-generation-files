  </transition>
  <!-- Rejection handler system task — clears stale tokens and loops back -->
  <transition>
    <id>t_reject_handler</id>
    <x>880</x>
    <y>208</y>
    <label>Handle Rejection</label>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>t_reject_handler_finish</id>
      <actions phase="pre">
        <action id="10">
<![CDATA[
            go_legal_approve: f.go_legal_approve, go_legal_reject: f.go_legal_reject,
            go_finance_approve: f.go_finance_approve, go_finance_reject: f.go_finance_reject,
            go_loop_legal: f.go_loop_legal, go_loop_finance: f.go_loop_finance,
            legal_decision: f.legal_decision, finance_decision: f.finance_decision,
            status: f.status;
            change go_legal_approve  value { 0 }
            change go_legal_reject   value { 0 }
            change go_finance_approve value { 0 }
            change go_finance_reject  value { 0 }
            change go_loop_legal      value { 0 }
            change go_loop_finance    value { 0 }
            change legal_decision     value { null }
            change finance_decision   value { null }
            change status             value { "Returned for Revision" }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
