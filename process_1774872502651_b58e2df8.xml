    <event type="finish">
      <id>t_final_finish</id>
      <actions phase="pre">
        <action id="11">
<![CDATA[
            go_final_issue: f.go_final_issue, go_final_reject: f.go_final_reject,
            final_decision: f.final_decision, status: f.status;
            if (final_decision.value == "issue") {
            change go_final_issue  value { 1 }
            change go_final_reject value { 0 }
            change status          value { "PO Issued" }
            } else {
            change go_final_issue  value { 0 }
            change go_final_reject value { 1 }
            change status          value { "PO Rejected" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="12">
<![CDATA[
            final_decision: f.final_decision, submitter_email: f.submitter_email,
            vendor_name: f.vendor_name, amount: f.amount, final_comment: f.final_comment;
            if (final_decision.value == "issue") {
            sendEmail(
            [submitter_email.value],
            "Purchase Order Issued",
            "Congratulations! Your purchase order for ${vendor_name.value} (Amount: ${amount.value}) has been approved and issued.\n\nComment: ${final_comment.value ?: 'No additional comments.'}"
            )
            } else {
            sendEmail(
            [submitter_email.value],
            "Purchase Order Finally Rejected",
            "Your purchase order for ${vendor_name.value} has been rejected by the Procurement Manager.\n\nComment: ${final_comment.value ?: 'No comment provided.'}"
            )
            }
            ]]>
        </action>
      </actions>
    </event>
