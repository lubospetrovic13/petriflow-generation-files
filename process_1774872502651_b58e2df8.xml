        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>5</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <event type="set">
          <id>finance_decision_set</id>
          <actions phase="post">
            <action id="7">
<![CDATA[
                finance_decision: f.finance_decision, finance_comment: f.finance_comment, t_finance_review: t.t_finance_review;
                if (finance_decision.value == "reject") {
                make finance_comment, required on t_finance_review when { true }
                } else {
                make finance_comment, optional on t_finance_review when { true }
                }
                ]]>
            </action>
          </actions>
        </event>
      </dataRef>
      <dataRef>
        <id>finance_comment</id>
        <logic>
          <behavior>editable</behavior>
