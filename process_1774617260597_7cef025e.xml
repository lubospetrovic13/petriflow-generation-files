<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>bug_tracker</id>
  <version>1.0.0</version>
  <initials>BUG</initials>
  <title>Bug Tracker</title>
  <icon>bug_report</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <caseEvents>
    <event type="create">
      <id>on_create</id>
      <actions phase="post">
        <action id="1">
<![CDATA[
            status: f.status;
            change status value { "Awaiting Triage" }
            ]]>
        </action>
      </actions>
    </event>
  </caseEvents>
  <role>
    <id>reporter</id>
    <title>Reporter</title>
  </role>
  <role>
    <id>triage</id>
    <title>Triage</title>
  </role>
  <role>
    <id>developer</id>
    <title>Developer</title>
  </role>
  <role>
    <id>qa</id>
    <title>QA Engineer</title>
  </role>
  <!-- ═══════════════════════════════════════════════════════════ DATA FIELDS -->
  <data type="text">
    <id>bug_title</id>
    <title>Bug Title</title>
  </data>
  <data type="text">
    <id>description</id>
    <title>Description</title>
  </data>
  <data type="text">
    <id>steps_to_reproduce</id>
    <title>Steps to Reproduce</title>
  </data>
  <data type="enumeration_map">
    <id>severity</id>
    <title>Severity</title>
    <options>
      <option key="critical">Critical</option>
      <option key="high">High</option>
      <option key="medium">Medium</option>
      <option key="low">Low</option>
    </options>
  </data>
  <data type="text">
    <id>affected_component</id>
    <title>Affected Component</title>
  </data>
  <data type="file">
    <id>screenshot</id>
    <title>Screenshot</title>
  </data>
  <data type="enumeration_map">
    <id>internal_priority</id>
    <title>Internal Priority</title>
    <options>
      <option key="p1">P1 - Urgent</option>
      <option key="p2">P2 - High</option>
      <option key="p3">P3 - Normal</option>
      <option key="p4">P4 - Low</option>
    </options>
  </data>
  <data type="text">
    <id>triage_notes</id>
    <title>Triage Notes</title>
  </data>
  <data type="user">
    <id>assigned_developer</id>
    <title>Assigned Developer</title>
  </data>
  <data type="text">
    <id>fix_description</id>
    <title>Fix Description</title>
  </data>
  <data type="enumeration_map">
    <id>qa_decision</id>
    <title>QA Decision</title>
    <options>
      <option key="pass">Pass - Mark Resolved</option>
      <option key="fail">Fail - Request Rework</option>
    </options>
  </data>
  <data type="text">
    <id>rejection_feedback</id>
    <title>Rejection Feedback</title>
  </data>
  <data type="text">
    <id>status</id>
    <title>Status</title>
  </data>
  <data type="text">
    <id>reporter_email</id>
    <title>Reporter Email</title>
  </data>
  <data type="dateTime">
    <id>resolved_at</id>
    <title>Resolved At</title>
  </data>
  <!-- routing fields -->
  <data type="number">
    <id>go_resolved</id>
    <title>Go Resolved</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_rework</id>
    <title>Go Rework</title>
    <init>0</init>
  </data>
  <!-- status panel taskRef -->
  <data type="taskRef">
    <id>status_panel</id>
    <title>My Bug Report</title>
    <init>t_status_view</init>
  </data>
  <!-- ═══════════════════════════════════════════════════════ TRANSITIONS -->
  <!-- 1. Submit Bug -->
  <transition>
    <id>t_submit</id>
    <x>208</x>
    <y>208</y>
    <label>Submit Bug Report</label>
    <icon>bug_report</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>reporter</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_submit</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Bug Report</title>
      <dataRef>
        <id>bug_title</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>steps_to_reproduce</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>severity</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>affected_component</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>3</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>screenshot</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>4</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>submit_finish</id>
      <actions phase="pre">
        <action id="2">
<![CDATA[
            status: f.status, reporter_email: f.reporter_email, bug_title: f.bug_title;
            change status value { "In Triage" }
            change reporter_email value { userService.loggedOrSystem.email }
            changeCaseProperty("title").about { bug_title.value ?: "New Bug" }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- 2. Triage -->
  <transition>
    <id>t_triage</id>
    <x>496</x>
    <y>208</y>
    <label>Triage Bug</label>
    <icon>manage_search</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>triage</id>
      <logic>
        <perform>true</perform>
