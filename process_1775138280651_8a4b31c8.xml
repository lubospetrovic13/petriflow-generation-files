<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>request_management</id>
  <version>1.0.0</version>
  <initials>REQ</initials>
  <title>Public Request Management</title>
  <icon>public</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>true</anonymousRole>
  <transitionRole>false</transitionRole>
  <role>
    <id>registrar</id>
    <title>Registration Desk</title>
  </role>
  <role>
    <id>lawyer</id>
    <title>Legal Department</title>
  </role>
  <role>
    <id>pr_officer</id>
    <title>PR Department</title>
  </role>
  <!-- Data Fields -->
  <data type="text">
    <id>name</id>
    <title>Name</title>
  </data>
  <data type="text">
    <id>surname</id>
    <title>Surname</title>
  </data>
  <data type="text">
    <id>email</id>
    <title>Email</title>
  </data>
  <data type="text">
    <id>phone</id>
    <title>Phone Number</title>
  </data>
  <data type="text">
    <id>description</id>
    <title>Request Description</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="file">
    <id>attachment</id>
    <title>Attachment</title>
  </data>
  <data type="enumeration_map">
    <id>route_selection</id>
    <title>Route To</title>
    <options>
      <option key="legal">Legal Department</option>
      <option key="pr">PR Department</option>
    </options>
  </data>
  <data type="text">
    <id>legal_statement</id>
    <title>Legal Statement</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="text">
    <id>pr_answer</id>
    <title>Final Answer</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="text">
    <id>status_label</id>
    <title>Current Status</title>
    <init>Submitted - Awaiting Triage</init>
  </data>
  <!-- Routing Flags -->
  <data type="number">
    <id>to_legal</id>
    <title>To Legal</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>to_pr</id>
    <title>To PR</title>
    <init>0</init>
  </data>
  <!-- Transitions -->
  <transition>
    <id>submit</id>
    <x>112</x>
    <y>208</y>
    <label>Submit Request</label>
    <icon>send</icon>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>default</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_submit</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Your Request</title>
      <dataRef>
        <id>name</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>surname</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>email</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>phone</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>attachment</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>ev_sub_fin</id>
      <actions phase="pre">
        <action id="1">
<![CDATA[
            status: f.status_label;
            change status value { "Under Review by Registrar" }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>triage</id>
    <x>496</x>
    <y>208</y>
    <label>Triage Request</label>
    <icon>assignment_ind</icon>
    <roleRef>
      <id>registrar</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_triage</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Review and Route</title>
      <dataRef>
        <id>name</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>surname</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>route_selection</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>ev_tri_fin</id>
      <actions phase="pre">
        <action id="2">
<![CDATA[
            sel: f.route_selection, to_l: f.to_legal, to_p: f.to_pr, status: f.status_label;
            if (sel.value == "legal") {
            change to_l value { 1 }; change to_p value { 0 }
            change status value { "Pending Legal Statement" }
            } else {
            change to_l value { 0 }; change to_p value { 1 }
            change status value { "Pending PR Response" }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>legal_review</id>
    <x>688</x>
    <y>112</y>
    <label>Legal Review</label>
    <icon>gavel</icon>
    <roleRef>
      <id>lawyer</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_legal</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Legal Statement</title>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>ev_leg_fin</id>
      <actions phase="pre">
        <action id="3">
<![CDATA[
            status: f.status_label, t_status: t.status_view;
            change status value { "Pending PR Response" }
            make legal_statement, visible on t_status when { true }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>pr_response</id>
    <x>880</x>
    <y>208</y>
    <label>PR Response</label>
    <icon>chat</icon>
    <roleRef>
      <id>pr_officer</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_pr</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Final Answer</title>
      <dataRef>
        <id>description</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>pr_answer</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>ev_pr_fin</id>
      <actions phase="pre">
        <action id="4">
<![CDATA[
            status: f.status_label, t_status: t.status_view, ans: f.pr_answer;
            change status value { "Completed" }
            make pr_answer, visible on t_status when { true }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>status_view</id>
    <x>496</x>
    <y>16</y>
    <label>Request Status</label>
    <icon>info</icon>
    <roleRef>
      <id>default</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_status</id>
      <cols>1</cols>
      <layout>grid</layout>
      <title>Current Status</title>
      <dataRef>
        <id>status_label</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>legal_statement</id>
        <logic>
          <behavior>hidden</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>pr_answer</id>
        <logic>
          <behavior>hidden</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <!-- Places -->
  <place>
    <id>start</id>
    <x>16</x>
    <y>208</y>
    <label>Start</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_triage</id>
    <x>304</x>
    <y>208</y>
    <label>Pending Triage</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_legal</id>
    <x>688</x>
    <y>208</y>
    <label>Legal Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_pr</id>
    <x>880</x>
    <y>304</y>
    <label>PR Queue</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_done</id>
    <x>1072</x>
    <y>208</y>
    <label>Done</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_status</id>
    <x>304</x>
    <y>16</y>
    <label>Status Active</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <!-- Arcs -->
  <arc>
    <id>a1</id>
    <type>regular</type>
    <sourceId>start</sourceId>
    <destinationId>submit</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2</id>
    <type>regular</type>
    <sourceId>submit</sourceId>
    <destinationId>p_triage</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3</id>
    <type>regular</type>
    <sourceId>submit</sourceId>
    <destinationId>p_status</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a4</id>
    <type>regular</type>
    <sourceId>p_triage</sourceId>
    <destinationId>triage</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <!-- XOR Split from Triage -->
  <arc>
    <id>a5</id>
    <type>regular</type>
    <sourceId>triage</sourceId>
    <destinationId>p_legal</destinationId>
    <multiplicity>0</multiplicity>
    <reference>to_legal</reference>
  </arc>
  <arc>
    <id>a6</id>
    <type>regular</type>
    <sourceId>triage</sourceId>
    <destinationId>p_pr</destinationId>
    <multiplicity>0</multiplicity>
    <reference>to_pr</reference>
  </arc>
  <arc>
    <id>a7</id>
    <type>regular</type>
    <sourceId>p_legal</sourceId>
    <destinationId>legal_review</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a8</id>
    <type>regular</type>
    <sourceId>legal_review</sourceId>
    <destinationId>p_pr</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a9</id>
    <type>regular</type>
    <sourceId>p_pr</sourceId>
    <destinationId>pr_response</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a10</id>
    <type>regular</type>
    <sourceId>pr_response</sourceId>
    <destinationId>p_done</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <!-- Persistent Status View -->
  <arc>
    <id>a11</id>
    <type>read</type>
    <sourceId>p_status</sourceId>
    <destinationId>status_view</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
</document>