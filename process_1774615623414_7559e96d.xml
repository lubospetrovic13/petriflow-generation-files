        <action id="4">
<![CDATA[
            to_legal: f.to_legal, to_pr: f.to_pr, route_decision: f.route_decision, status: f.status;
            if (route_decision.value == "legal") {
            change to_legal value { 1 }; change to_pr value { 0 };
            change status value { "Routed to Legal" }
            } else {
            change to_legal value { 0 }; change to_pr value { 1 };
            change status value { "Routed to PR" }
            }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="5">
<![CDATA[
            async.run {
            if (f.route_decision.value == "legal") { assignTask("legal_review"); finishTask("legal_review") }
            else { assignTask("pr_response"); finishTask("pr_response") }
            }
            ]]>
        </action>
      </actions>
    </event>
