<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>invoice_process</id>
  <version>1.0.1</version>
  <initials>INV</initials>
  <title>Invoice Process</title>
  <icon>receipt</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <role>
    <id>system</id>
    <title>System</title>
  </role>
  <data type="text">
    <id>invoice_number</id>
    <title>Invoice Number</title>
  </data>
  <data type="number">
    <id>amount</id>
    <title>Amount</title>
    <component>
      <name>currency</name>
    </component>
  </data>
  <data type="date">
    <id>invoice_date</id>
    <title>Invoice Date</title>
  </data>
  <data type="file">
    <id>invoice_file</id>
    <title>Invoice Document</title>
  </data>
  <data type="enumeration_map">
    <id>order_link</id>
    <title>Link to Order</title>
  </data>
  <data type="enumeration_map">
    <id>approval</id>
    <title>Approval Status</title>
    <options>
      <option key="pending">Pending</option>
      <option key="approved">Approved</option>
      <option key="rejected">Rejected</option>
    </options>
    <init>pending</init>
  </data>
  <transition>
    <id>register</id>
    <x>304</x>
    <y>208</y>
    <label>Register Invoice</label>
    <icon>add_box</icon>
    <assignPolicy>auto</assignPolicy>
    <event type="assign">
      <id>reg_a</id>
      <actions phase="pre">
        <action id="10">
<![CDATA[
            order_link: f.order_link;
            def orders = findCases { it.processIdentifier.eq(workspace + "order_process") }
            .findAll { c -> (c.activePlaces?.get("p_open") ?: 0) > 0 }
            .collectEntries { [(it.stringId): "Order: " + it.title + " (" + it.stringId + ")"] }
            change order_link options { orders }
            ]]>
        </action>
      </actions>
    </event>
    <dataGroup>
      <id>dg_reg</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Invoice Info</title>
      <dataRef>
        <id>order_link</id>
        <logic>
          <behavior>required</behavior>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>invoice_number</id>
        <logic>
          <behavior>required</behavior>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>amount</id>
        <logic>
          <behavior>required</behavior>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>invoice_date</id>
        <logic>
          <behavior>required</behavior>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>invoice_file</id>
        <logic>
          <behavior>required</behavior>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>2</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>reg_f</id>
      <actions phase="post">
        <action id="11">
<![CDATA[
            order_link: f.order_link;
            async.run {
            def orderCase = findCase { it.stringId.eq(order_link.value) }
            if (orderCase) {
            // Hledáme úkol, který je trvale živý na p_approval_place
            def myTask = findTask { it.transitionId.eq("invoice_approval").and(it.caseId.eq(useCase.stringId)) }
            if (myTask) {
            def currentList = orderCase.dataSet?.get("linked_invoices")?.value ?: []
            setData("invoice_panel_target", orderCase, [
            "linked_invoices": ["value": currentList + myTask.stringId, "type": "taskRef"]
            ])
            }
            }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>invoice_approval</id>
    <x>496</x>
    <y>16</y>
    <label>Invoice Approval</label>
    <icon>check_circle</icon>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_inv_app</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Invoice Review</title>
      <dataRef>
        <id>invoice_number</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>amount</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>invoice_file</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
        <component>
          <name>preview</name>
        </component>
      </dataRef>
      <dataRef>
        <id>approval</id>
        <logic>
          <behavior>required</behavior>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <place>
    <id>p_start</id>
    <x>112</x>
    <y>208</y>
    <label>New</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_done</id>
    <x>496</x>
    <y>208</y>
    <label>Registered</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_approval_place</id>
    <x>304</x>
    <y>16</y>
    <label>Approval State</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <arc>
    <id>a1</id>
    <type>regular</type>
    <sourceId>p_start</sourceId>
    <destinationId>register</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2</id>
    <type>regular</type>
    <sourceId>register</sourceId>
    <destinationId>p_done</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3</id>
    <type>read</type>
    <sourceId>p_approval_place</sourceId>
    <destinationId>invoice_approval</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
</document>