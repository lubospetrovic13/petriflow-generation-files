<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>order_process</id>
  <version>1.0.0</version>
  <initials>ORD</initials>
  <title>Order Management</title>
  <icon>shopping_cart</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <caseEvents>
    <event type="create">
      <id>order_create</id>
      <actions phase="post">
        <action id="1">
<![CDATA[
            changeCaseProperty("title").about { "New Order" }
            changeCaseProperty("color").about { "blue" }
            assignRole("approver", petriNet)
            ]]>
        </action>
      </actions>
    </event>
  </caseEvents>
  <role>
    <id>submitter</id>
    <title>Submitter</title>
  </role>
  <role>
    <id>manager</id>
    <title>Manager</title>
  </role>
  <role>
    <id>approver</id>
    <title>Invoice Approver</title>
  </role>
  <data type="text">
    <id>subject</id>
    <title>Subject</title>
  </data>
  <data type="text">
    <id>supplier</id>
    <title>Supplier Name</title>
  </data>
  <data type="date">
    <id>order_date</id>
    <title>Order Date</title>
  </data>
  <data type="text">
    <id>notes</id>
    <title>Notes</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="text">
    <id>manager_comment</id>
    <title>Manager Comment</title>
    <component>
      <name>textarea</name>
    </component>
  </data>
  <data type="enumeration_map">
    <id>decision</id>
    <title>Manager Decision</title>
    <options>
      <option key="approve">Approve</option>
      <option key="reject">Reject</option>
    </options>
  </data>
  <data type="number">
    <id>go_approve</id>
    <title>Go Approve</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_reject</id>
    <title>Go Reject</title>
    <init>0</init>
  </data>
  <data type="taskRef">
    <id>linked_invoices</id>
    <title>Linked Invoices</title>
  </data>
  <data type="text">
    <id>status</id>
    <title>Current Status</title>
    <init>Draft</init>
  </data>
  <transition>
    <id>submit</id>
    <x>208</x>
    <y>208</y>
    <label>Submit Order</label>
    <icon>send</icon>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>submitter</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_submit</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Order Details</title>
      <dataRef>
        <id>subject</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>supplier</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>order_date</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>notes</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>sub_fin</id>
      <actions phase="pre">
        <action id="2">
<![CDATA[
            status: f.status, subject: f.subject;
            change status value { "Pending Approval" }
            changeCaseProperty("title").about { subject.value }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>review</id>
    <x>400</x>
    <y>208</y>
    <label>Manager Review</label>
    <icon>rate_review</icon>
    <assignPolicy>auto</assignPolicy>
    <roleRef>
      <id>manager</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_review</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Review Decision</title>
      <dataRef>
        <id>subject</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>decision</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>manager_comment</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>rev_fin</id>
      <actions phase="pre">
        <action id="3">
<![CDATA[
            dec: f.decision, comm: f.manager_comment, go_app: f.go_approve, go_rej: f.go_reject, status: f.status;
            if (dec.value == "approve") {
            change go_app value { 1 }; change go_rej value { 0 }
            change status value { "Approved" }
            changeCaseProperty("color").about { "green" }
            } else {
            if (!comm.value) throw new java.lang.IllegalStateException("Comment is required for rejection")
            change go_app value { 0 }; change go_rej value { 1 }
            change status value { "Rejected - Needs Correction" }
            changeCaseProperty("color").about { "orange" }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <transition>
    <id>order_dashboard</id>
    <x>592</x>
    <y>208</y>
    <label>Order Dashboard</label>
    <icon>dashboard</icon>
    <roleRef>
      <id>submitter</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_dash</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Order and Invoices</title>
      <dataRef>
        <id>status</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>manager_comment</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>0</y>
          <rows>1</rows>
          <cols>1</cols>
        </layout>
      </dataRef>
      <dataRef>
        <id>linked_invoices</id>
        <logic>
          <behavior>visible</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>2</cols>
        </layout>
      </dataRef>
    </dataGroup>
  </transition>
  <place>
    <id>p_start</id>
    <x>112</x>
    <y>208</y>
    <label>Draft</label>
    <tokens>1</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_pending</id>
    <x>304</x>
    <y>208</y>
    <label>Pending</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <place>
    <id>p_dash</id>
    <x>592</x>
    <y>112</y>
    <label>Dashboard State</label>
    <tokens>0</tokens>
    <static>false</static>
  </place>
  <arc>
    <id>a1</id>
    <type>regular</type>
    <sourceId>p_start</sourceId>
    <destinationId>submit</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2</id>
    <type>regular</type>
    <sourceId>submit</sourceId>
    <destinationId>p_pending</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3</id>
    <type>regular</type>
    <sourceId>p_pending</sourceId>
    <destinationId>review</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a4</id>
    <type>regular</type>
    <sourceId>review</sourceId>
    <destinationId>p_dash</destinationId>
    <multiplicity>0</multiplicity>
    <reference>go_approve</reference>
  </arc>
  <arc>
    <id>a5</id>
    <type>regular</type>
    <sourceId>review</sourceId>
    <destinationId>p_start</destinationId>
    <multiplicity>0</multiplicity>
    <reference>go_reject</reference>
    <breakpoint>
      <x>400</x>
      <y>368</y>
    </breakpoint>
    <breakpoint>
      <x>112</x>
      <y>368</y>
    </breakpoint>
  </arc>
  <arc>
    <id>a6</id>
    <type>read</type>
    <sourceId>p_dash</sourceId>
    <destinationId>order_dashboard</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
</document>