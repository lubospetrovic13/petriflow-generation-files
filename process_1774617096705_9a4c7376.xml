  <!-- ARCS -->
  <!-- start → t_submit → p_submitted AND p_status -->
  <arc>
    <id>a1</id>
    <type>regular</type>
    <sourceId>start</sourceId>
    <destinationId>t_submit</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a2</id>
    <type>regular</type>
    <sourceId>t_submit</sourceId>
    <destinationId>p_submitted</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a3</id>
    <type>regular</type>
    <sourceId>t_submit</sourceId>
    <destinationId>p_status</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <!-- Persistent status read arc -->
  <arc>
    <id>a4</id>
    <type>read</type>
    <sourceId>p_status</sourceId>
    <destinationId>t_status</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <!-- p_submitted → t_review → p_routing -->
  <arc>
    <id>a5</id>
    <type>regular</type>
    <sourceId>p_submitted</sourceId>
    <destinationId>t_review</destinationId>
    <multiplicity>1</multiplicity>
  </arc>
  <arc>
    <id>a6</id>
