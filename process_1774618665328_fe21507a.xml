<?xml version="1.0" encoding="UTF-8"?>
<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
  <id>procurement_workflow</id>
  <version>1.0.0</version>
  <initials>PO</initials>
  <title>Purchase Order Workflow</title>
  <icon>shopping_cart</icon>
  <defaultRole>true</defaultRole>
  <anonymousRole>false</anonymousRole>
  <transitionRole>false</transitionRole>
  <caseEvents>
    <event type="create">
      <id>on_create</id>
      <actions phase="post">
        <action id="1">
<![CDATA[
            status: f.status;
            change status value { "Draft" }
            ]]>
        </action>
      </actions>
    </event>
  </caseEvents>
  <role>
    <id>submitter</id>
    <title>Submitter</title>
  </role>
  <role>
    <id>legal</id>
    <title>Legal Reviewer</title>
  </role>
  <role>
    <id>finance</id>
    <title>Finance Reviewer</title>
  </role>
  <role>
    <id>procurement_manager</id>
    <title>Procurement Manager</title>
  </role>
  <role>
    <id>system</id>
    <title>System</title>
  </role>
  <!-- ═══ DATA FIELDS ═══ -->
  <!-- PO Form fields -->
  <data type="text">
    <id>vendor_name</id>
    <title>Vendor Name</title>
  </data>
  <data type="number">
    <id>amount</id>
    <title>Amount</title>
  </data>
  <data type="enumeration_map">
    <id>category</id>
    <title>Category</title>
    <options>
      <option key="software">Software</option>
      <option key="hardware">Hardware</option>
      <option key="services">Services</option>
      <option key="other">Other</option>
    </options>
  </data>
  <data type="text">
    <id>business_justification</id>
    <title>Business Justification</title>
  </data>
  <data type="text">
    <id>detailed_description</id>
    <title>Detailed Description</title>
  </data>
  <data type="file">
    <id>supporting_document</id>
    <title>Supporting Document</title>
  </data>
  <!-- Status and outcome fields -->
  <data type="text">
    <id>status</id>
    <title>Current Status</title>
    <init>Draft</init>
  </data>
  <data type="text">
    <id>submitter_email</id>
    <title>Submitter Email</title>
  </data>
  <!-- Legal review fields -->
  <data type="enumeration_map">
    <id>legal_decision</id>
    <title>Legal Decision</title>
    <options>
      <option key="approve">Approve</option>
      <option key="reject">Reject</option>
    </options>
  </data>
  <data type="text">
    <id>legal_comment</id>
    <title>Legal Comment</title>
  </data>
  <!-- Finance review fields -->
  <data type="enumeration_map">
    <id>finance_decision</id>
    <title>Finance Decision</title>
    <options>
      <option key="approve">Approve</option>
      <option key="reject">Reject</option>
    </options>
  </data>
  <data type="text">
    <id>finance_comment</id>
    <title>Finance Comment</title>
  </data>
  <!-- Routing number fields -->
  <data type="number">
    <id>legal_go_approve</id>
    <title>Legal Go Approve</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>legal_go_reject</id>
    <title>Legal Go Reject</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>finance_go_approve</id>
    <title>Finance Go Approve</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>finance_go_reject</id>
    <title>Finance Go Reject</title>
    <init>0</init>
  </data>
  <!-- AND-join token counter -->
  <data type="number">
    <id>approvals_count</id>
    <title>Approvals Count</title>
    <init>0</init>
  </data>
  <!-- Final manager decision routing -->
  <data type="enumeration_map">
    <id>manager_decision</id>
    <title>Manager Decision</title>
    <options>
      <option key="issue">Issue PO</option>
      <option key="reject">Reject PO</option>
    </options>
  </data>
  <data type="text">
    <id>manager_comment</id>
    <title>Manager Comment</title>
  </data>
  <data type="number">
    <id>go_issue</id>
    <title>Go Issue</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_final_reject</id>
    <title>Go Final Reject</title>
    <init>0</init>
  </data>
  <!-- Revision tracking -->
  <data type="number">
    <id>revision_number</id>
    <title>Revision</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_revise</id>
    <title>Go Revise</title>
    <init>0</init>
  </data>
  <data type="number">
    <id>go_split</id>
    <title>Go Split</title>
    <init>0</init>
  </data>
  <!-- ═══ TRANSITIONS ═══ -->
  <!-- Submit PO -->
  <transition>
    <id>t_submit</id>
    <x>304</x>
    <y>208</y>
    <label>Submit Purchase Order</label>
    <icon>send</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>submitter</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <dataGroup>
      <id>dg_submit</id>
      <cols>2</cols>
      <layout>grid</layout>
      <title>Purchase Order Details</title>
      <dataRef>
        <id>vendor_name</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>0</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>amount</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>category</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>1</x>
          <y>1</y>
          <rows>1</rows>
          <cols>1</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>business_justification</id>
        <logic>
          <behavior>editable</behavior>
          <behavior>required</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>2</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
      <dataRef>
        <id>detailed_description</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>3</y>
          <rows>2</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
        <component>
          <name>textarea</name>
        </component>
      </dataRef>
      <dataRef>
        <id>supporting_document</id>
        <logic>
          <behavior>editable</behavior>
        </logic>
        <layout>
          <x>0</x>
          <y>5</y>
          <rows>1</rows>
          <cols>2</cols>
          <template>material</template>
          <appearance>outline</appearance>
        </layout>
      </dataRef>
    </dataGroup>
    <event type="finish">
      <id>t_submit_finish</id>
      <actions phase="pre">
        <action id="2">
<![CDATA[
            status: f.status, submitter_email: f.submitter_email,
            revision_number: f.revision_number, go_split: f.go_split;
            change status value { "Pending Review" }
            change submitter_email value { userService.loggedOrSystem.email }
            def rev = (revision_number.value as Integer) ?: 0
            change revision_number value { (rev + 1) as Double }
            change go_split value { 1 }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- AND-split system task -->
  <transition>
    <id>t_split</id>
    <x>496</x>
    <y>208</y>
