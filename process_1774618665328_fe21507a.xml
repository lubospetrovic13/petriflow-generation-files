    <event type="finish">
      <id>t_legal_finish</id>
      <actions phase="pre">
        <action id="3">
<![CDATA[
            legal_go_approve: f.legal_go_approve, legal_go_reject: f.legal_go_reject,
            legal_decision: f.legal_decision;
            if (legal_decision.value == "approve") {
            change legal_go_approve value { 1 }
            change legal_go_reject value { 0 }
            } else {
            change legal_go_approve value { 0 }
            change legal_go_reject value { 1 }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
