  <!-- Rejection merge system task — fires when any rejection token arrives -->
  <transition>
    <id>t_rejection_merge</id>
    <x>1072</x>
    <y>256</y>
    <label>Process Rejection</label>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>t_rejection_merge_finish</id>
      <actions phase="pre">
        <action id="5">
<![CDATA[
            status: f.status, go_revise: f.go_revise;
            change status value { "Rejected - Revision Required" }
            change go_revise value { 1 }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="6">
<![CDATA[
            submitter_email: f.submitter_email, legal_decision: f.legal_decision,
            legal_comment: f.legal_comment, finance_decision: f.finance_decision,
            finance_comment: f.finance_comment;
            def legalPart = "Legal: ${legal_decision.value ?: 'pending'} - ${legal_comment.value ?: ''}"
            def financePart = "Finance: ${finance_decision.value ?: 'pending'} - ${finance_comment.value ?: ''}"
            sendEmail(
            [submitter_email.value],
            "Purchase Order Rejected - Revision Required",
            "Your purchase order has been rejected and requires revision.\n\n${legalPart}\n\n${financePart}\n\nPlease revise and resubmit."
            )
            ]]>
        </action>
      </actions>
    </event>
  </transition>
  <!-- AND-join + approval system task -->
  <transition>
    <id>t_both_approved</id>
    <x>1072</x>
    <y>112</y>
    <label>Both Approved</label>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>t_both_approved_finish</id>
      <actions phase="pre">
        <action id="7">
<![CDATA[
            status: f.status;
            change status value { "Pending Manager Decision" }
            ]]>
        </action>
      </actions>
      <actions phase="post">
        <action id="8">
<![CDATA[
            async.run {
            def t = findTask { it.transitionId.eq("t_manager_decision").and(it.caseId.eq(useCase.stringId)) }
            if (t) { assignTask(t, userService.loggedOrSystem); finishTask(t, userService.loggedOrSystem) }
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
