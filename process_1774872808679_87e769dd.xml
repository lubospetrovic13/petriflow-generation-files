  <!-- Evaluate system task — fires when both tokens arrive in p_join (mult=2) -->
  <transition>
    <id>t_evaluate</id>
    <x>784</x>
    <y>208</y>
    <label>Evaluate Reviews</label>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>t_evaluate_finish</id>
      <actions phase="pre">
        <action id="8">
<![CDATA[
            go_approved: f.go_approved, go_rejected: f.go_rejected,
            legal_decision: f.legal_decision, finance_decision: f.finance_decision,
            status: f.status, submitter_email: f.submitter_email,
            legal_comment: f.legal_comment, finance_comment: f.finance_comment;
            def bothApproved = (legal_decision.value == "approve" && finance_decision.value == "approve")
            if (bothApproved) {
            change go_approved value { 1 }
            change go_rejected value { 0 }
            change status value { "Pending Final Decision" }
            } else {
            change go_approved value { 0 }
            change go_rejected value { 1 }
            def reasons = []
            if (legal_decision.value == "reject")   reasons << "Legal: ${legal_comment.value ?: 'No comment.'}"
            if (finance_decision.value == "reject")  reasons << "Finance: ${finance_comment.value ?: 'No comment.'}"
            change status value { "Rejected — Returned for Revision" }
            sendEmail(
            [submitter_email.value],
            "Purchase Order Rejected — Revision Required",
            "Your purchase order was rejected and returned for revision.\n\n${reasons.join('\n\n')}\n\nPlease revise and resubmit."
            )
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
