  <transition>
    <id>ai_classify</id>
    <x>400</x>
    <y>208</y>
    <label>AI Classify</label>
    <icon>smart_toy</icon>
    <assignPolicy>auto</assignPolicy>
    <priority>1</priority>
    <roleRef>
      <id>system</id>
      <logic>
        <perform>true</perform>
      </logic>
    </roleRef>
    <event type="finish">
      <id>ai_classify_finish</id>
      <actions phase="post">
        <action id="2">
<![CDATA[
            api_key: f.api_key, subject: f.subject, body: f.body, category: f.category, entities: f.entities, response_draft: f.response_draft;
            def prompt = """Classify the following email into one of: Complaint, Inquiry, Order, Spam, Other.
            Extract key entities (names, dates, amounts) as plain text.
            Generate a suggested response draft.
            
            Email Subject: ${subject.value}
            Email Body:
            ${body.value}
            
            Respond in JSON:
            {
            "category": "...",
            "entities": "...",
            "response_draft": "..."
            }
            """
            async.run {
            def conn = (java.net.HttpURLConnection) new java.net.URL("https://api.openai.com/v1/chat/completions").openConnection()
            conn.setRequestMethod("POST")
            conn.setRequestProperty("Content-Type", "application/json")
            conn.setRequestProperty("Authorization", "Bearer ${api_key.value}")
            conn.setDoOutput(true); conn.setConnectTimeout(15000); conn.setReadTimeout(60000)
            conn.outputStream.write(groovy.json.JsonOutput.toJson([
            model: "gpt-4o-mini",
            messages: [[role: "user", content: prompt]]
            ]).getBytes("UTF-8"))
            def bodyText = ""
            try { bodyText = conn.inputStream.getText("UTF-8") }
            catch (e) { bodyText = conn.errorStream?.getText("UTF-8") ?: '{"error":"unreachable"}' }
            def content = new groovy.json.JsonSlurper().parseText(bodyText)?.choices?.getAt(0)?.message?.content ?: "{}"
            def normalized = content.replaceAll('(?m)^```(?:json)?\\s*','').replaceAll('(?m)^```\\s*$','').trim()
            def parsed = [:]
            try { parsed = new groovy.json.JsonSlurper().parseText(normalized) }
            catch (e) { parsed = [:] }
            def cat = (parsed.category ?: "").toLowerCase()
            def cat_map = ["complaint":"complaint","inquiry":"inquiry","order":"order","spam":"spam","other":"other"]
            def mapped_cat = cat_map[cat] ?: "other"
            setData("ai_classify", useCase, [
            category: ["value": mapped_cat, "type": "enumeration_map"],
            entities: ["value": parsed.entities ?: "", "type": "text"],
            response_draft: ["value": parsed.response_draft ?: "", "type": "text"]
            ])
            }
            ]]>
        </action>
      </actions>
    </event>
  </transition>
